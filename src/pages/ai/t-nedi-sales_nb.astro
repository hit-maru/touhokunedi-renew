---
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>東北ネヂなんでもAI（販売編）</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen px-4 py-12">

  <div class="max-w-xl mx-auto space-y-8">

    {/* ヘッダー */}
    <div>
      <p class="text-xs font-bold tracking-widest text-[#008B9B] uppercase mb-2">Tohoku Bolt MFG. Co., Ltd.</p>
      <h1 class="text-2xl font-bold text-gray-900 mb-3">東北ネヂなんでもAI（販売編）</h1>
      <p class="text-sm text-gray-700 leading-relaxed">
        東北ネヂの製品情報や会社情報について、AIがお答えします。
      </p>
    </div>

    {/* 例えばこんな質問 */}
    <div>
      <h3 class="text-sm font-bold text-gray-800 mb-3">例えばこんな質問ができます</h3>
      <div class="bg-gray-100 rounded-sm p-4 text-sm text-gray-600 leading-relaxed space-y-1.5">
        <p>・M5の小ねじはありますか？</p>
        <p>・ステンレス製の製品を探しています</p>
        <p>・最小ロットを教えてください</p>
        <p>・東北ネヂはどんな会社ですか？</p>
      </div>
    </div>

    {/* ご利用方法 */}
    <div>
      <h3 class="text-sm font-bold text-gray-800 mb-3">ご利用方法</h3>
      <ol class="space-y-2 text-sm text-gray-700 list-decimal list-inside">
        <li>お名前・会社名・メールアドレスを入力</li>
        <li>「利用を開始する」をクリック</li>
        <li>Googleアカウントでログイン</li>
        <li>AIに自由に質問</li>
      </ol>
    </div>

    {/* ご利用にあたって */}
    <div>
      <h3 class="text-sm font-bold text-gray-800 mb-3">ご利用にあたって</h3>
      <ul class="space-y-1.5 text-sm text-gray-600 leading-relaxed">
        <li>・本サービスの利用にはGoogleアカウントが必要です。</li>
        <li>・AIによる回答のため、内容は参考情報としてご利用ください。</li>
        <li>・個人情報や機密情報の入力はお控えください。</li>
      </ul>
    </div>

    {/* フォーム */}
    <div class="bg-white border border-gray-200 rounded-sm shadow-sm p-6">
      <h2 class="text-base font-bold text-gray-900 border-b border-gray-200 pb-2 mb-5">ご利用登録</h2>

      <form id="entry-form" class="space-y-5" novalidate>

        <input type="hidden" name="type" value="販売AI" />
        <input type="hidden" name="redirect" value="https://notebooklm.google.com/notebook/626db445-4bf2-4056-8abd-8c0a682eb4b4/preview" />

        <div>
          <label for="name" class="block text-xs font-bold text-gray-700 mb-1">お名前 <span class="text-red-500">*</span></label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="山田 太郎"
            class="w-full border border-gray-300 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-[#008B9B] focus:ring-1 focus:ring-[#008B9B] transition-colors"
          />
        </div>

        <div>
          <label for="company" class="block text-xs font-bold text-gray-700 mb-1">会社名 <span class="text-red-500">*</span></label>
          <input
            type="text"
            id="company"
            name="company"
            required
            placeholder="株式会社〇〇"
            class="w-full border border-gray-300 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-[#008B9B] focus:ring-1 focus:ring-[#008B9B] transition-colors"
          />
        </div>

        <div>
          <label for="email" class="block text-xs font-bold text-gray-700 mb-1">メールアドレス <span class="text-red-500">*</span></label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="example@company.co.jp"
            class="w-full border border-gray-300 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-[#008B9B] focus:ring-1 focus:ring-[#008B9B] transition-colors"
          />
        </div>

        {/* 同意チェック＋説明文 */}
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <input
              type="checkbox"
              id="consent"
              name="consent"
              class="mt-0.5 w-4 h-4 accent-[#008B9B] shrink-0 cursor-pointer"
            />
            <label for="consent" class="text-sm text-gray-700 font-bold leading-relaxed cursor-pointer">
              個人情報の取扱いについて同意する
            </label>
          </div>

          {/* 個人情報の取扱いについて（小さく） */}
          <div class="ml-7 bg-gray-50 border border-gray-200 rounded-sm p-3">
            <p class="text-[11px] font-bold text-gray-500 mb-1.5">個人情報の取扱いについて</p>
            <p class="text-[11px] text-gray-500 leading-relaxed">
              当フォームで取得した氏名・会社名・メールアドレスは、本サービスの利用状況把握およびお問い合わせ対応のために利用します。
            </p>
            <p class="text-[11px] text-gray-500 leading-relaxed mt-1.5">
              取得した情報を、ご本人の同意なく第三者へ提供することはありません。
            </p>
            <p class="text-[11px] text-gray-500 leading-relaxed mt-1.5">
              なお、NotebookLMに入力された質問内容は東北ネヂ製造株式会社が取得・保存するものではありません。
            </p>
          </div>
        </div>

        <div id="error-msg" class="hidden text-xs text-red-500 text-center">全項目の入力と同意チェックが必要です。</div>

        <button
          type="submit"
          id="submit-btn"
          class="w-full bg-[#008B9B] hover:bg-[#007080] text-white font-bold text-sm py-3 rounded-sm transition-colors tracking-widest"
        >
          利用を開始する
        </button>

      </form>
    </div>

  </div>

  <script is:inline>
    const GAS_URL = "https://script.google.com/macros/s/AKfycbwazFTHka-aOckdW11dobGREBaUFdBN46g2ijyfOXQAeTQaIUwZ88RxouSBG14VPMbc/exec";

    document.getElementById("entry-form").addEventListener("submit", async (e) => {
      e.preventDefault();

      const form = e.target;
      const name = form.name.value.trim();
      const company = form.company.value.trim();
      const email = form.email.value.trim();
      const consent = form.consent.checked;
      const errorMsg = document.getElementById("error-msg");
      const btn = document.getElementById("submit-btn");
      const redirect = form.redirect.value;

      if (!name || !company || !email || !consent) {
        errorMsg.classList.remove("hidden");
        return;
      }
      errorMsg.classList.add("hidden");

      btn.disabled = true;
      btn.textContent = "送信中...";

      const payload = new FormData();
      payload.append("type", form.type.value);
      payload.append("name", name);
      payload.append("company", company);
      payload.append("email", email);

      try {
        await fetch(GAS_URL, { method: "POST", body: payload, mode: "no-cors" });
      } catch (_) {
        // CORSエラーは無視してリダイレクト続行
      }

      if (typeof gtag === "function") {
        gtag("event", "notebooklm_open", {
          notebook_type: "sales",
          event_callback: function () {
            window.location.href = redirect;
          },
          event_timeout: 1000
        });
      } else {
        window.location.href = redirect;
      }
      
    });
  </script>

</body>
</html>
