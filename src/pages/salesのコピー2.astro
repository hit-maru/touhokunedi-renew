        function buildPdfTable(spec) {
          const th = isMain => `background:${isMain?'#008B9B':'#1a1a18'};color:#fff;font-size:9px;font-family:monospace;padding:7px 10px;text-align:center;white-space:nowrap;border:1px solid #fff`;
          const td = (i,isMain) => `padding:6px 10px;text-align:center;font-family:monospace;font-size:10px;border:1px solid #ddd;background:${isMain?(i%2===0?'#e0f5f7':'#d0eef0'):(i%2===0?'#fff':'#f9f9f9')};${isMain?'font-weight:600;color:#008B9B':''}`;
          let html = `<table style="width:100%;border-collapse:collapse">`;
          if(spec.headerRows){
            html+=`<thead><tr>`;
            spec.headerRows.forEach(([span,lbl,isMain])=>{html+=`<th colspan="${span}" style="${th(isMain)}">${lbl}</th>`;});
            html+=`</tr><tr>`;
            spec.subHeaderRow.forEach((sub,ci)=>{html+=`<th style="${th(ci===0)};font-size:8px;background:${ci===0?'#008B9B':'#333'}">${sub}</th>`;});
            html+=`</tr></thead>`;
          } else {
            html+=`<thead><tr>`;
            spec.columns.forEach((col,ci)=>{html+=`<th style="${th(ci===spec.mainCol)}">${col}</th>`;});
            html+=`</tr></thead>`;
          }
          html+=`<tbody>`;
          spec.rows.forEach((row,ri)=>{
            html+=`<tr>`;
            row.forEach((cell,ci)=>{
              const isMain=ci===spec.mainCol;
              const val=String(cell===null||cell===undefined?'−':cell).replace(/\n/g,'<br>');
              html+=`<td style="${td(ri,isMain)}">${val}</td>`;
            });
            html+=`</tr>`;
          });
          html+=`</tbody></table>`;
          return html;
        }

        function loadScript(src) {
          return new Promise((res,rej)=>{
            if(document.querySelector(`script[src="${src}"]`)) return res();
            const s=document.createElement('script');
            s.src=src; s.onload=res; s.onerror=rej;
            document.head.appendChild(s);
          });
        }

        // 閉じる処理（準備中画面のリンクからも呼べるようwindowに公開）
        window.closeLightbox = function closeLightbox() {
