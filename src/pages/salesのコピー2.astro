---
// src/pages/sales.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="販売事業 | 東北ネヂ製造株式会社">

  <div id="top" class="bg-gray-100 pt-[90px] pb-8 border-b border-gray-200">
    <div class="container mx-auto px-2">
      <h1 class="text-4xl md:text-5xl font-mincho font-bold text-[#008B9B] mb-4">販売事業</h1>
      <p class="text-gray-500 font-serif tracking-wider uppercase">SALES BUSINESS</p>
    </div>
  </div>

  <div class="sticky top-20 bg-white/95 backdrop-blur z-40 border-b border-gray-100 shadow-sm">
    <div class="container mx-auto px-6 py-3">

      <div class="md:hidden relative">
        <select
          onchange="window.location.hash = this.value"
          class="w-full bg-white border border-[#008B9B]/30 text-[#008B9B] text-sm font-bold rounded-sm px-4 py-3 appearance-none focus:outline-none focus:ring-2 focus:ring-[#008B9B] font-mb101"
        >
          <option value="#">メニュー：セクションを選択</option>
          <option value="#products">取扱商品</option>
          <option value="#system">販売体制</option>
          <option value="#labo-2">ねぢラボ</option>
          <option value="#inquiry">お問合せ</option>
        </select>
        <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
          <svg class="w-4 h-4 text-[#008B9B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
          </svg>
        </div>
      </div>

      <nav class="hidden md:flex flex-row justify-center gap-10 text-[13px] font-bold text-gray-500 font-mb101 uppercase tracking-wide">
        <a href="#products" class="hover:text-[#008B9B] transition-colors">取扱商品</a>
        <a href="#system" class="hover:text-[#008B9B] transition-colors">販売体制</a>
        <a href="#labo-2" class="hover:text-[#008B9B] transition-colors">ねぢラボ</a>
        <a href="#inquiry" class="hover:text-[#008B9B] transition-colors">お問合せ</a>
      </nav>

    </div>
  </div>

  <div class="[&>section]:scroll-mt-[30px] md:[&>section]:scroll-mt-[20px]">

    {/* --- 取扱商品セクション --- */}
    <section id="products" class="pt-12 pb-12 bg-white">
      <div class="container mx-auto px-6">

        <div class="max-w-4xl mx-auto text-center mb-20">
          <h2 class="font-mb101 text-4xl md:text-5xl text-[#008B9B] mb-8 tracking-tighter">取扱商品</h2>
          <p class="font-futomin font-normal text-xl md:text-2xl text-gray-900 mb-12">総品種 10,000 種類以上在庫 / ねじならなんでも揃う</p>
        </div>

        <div class="max-w-6xl mx-auto mb-20">
          <div class="bg-gray-100 py-2 text-center mb-4 border border-gray-200">
            <span class="font-mb101 font-bold text-sm tracking-widest text-gray-700">取扱カテゴリー</span>
          </div>
          <p class="text-center text-gray-400 text-xs mb-6 font-medium">
            <span class="inline-flex items-center gap-2">
              <span class="inline-block w-2 h-2 rounded-full bg-[#008B9B]"></span>
              図面・規格マークの製品はクリックで規格表をご覧いただけます
              <span class="text-gray-300">／</span>
              <span class="inline-block w-2 h-2 rounded-full bg-gray-300"></span>
              その他の製品は規格表を順次公開予定
            </span>
          </p>

          {/* 写真カードグリッド — data-spec-id に products.json の id（なければ空文字で「準備中」表示） */}
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
            {[
              { name: "六角ボルト",          img: "022_20250114_061736_web.webp", specId: "B00000"  },
              { name: "ハイテンションボルト", img: "2a-cut_web.webp",              specId: ""        },
              { name: "Uボルト",             img: "item-ubolt_web.webp",           specId: "C00700"  },
              { name: "六角穴付きボルト",     img: "019_20250114_061736_web.webp", specId: "A0000C"  },
              { name: "止めネジ",            img: "018_20250114_061736_web.webp",  specId: ""        },
              { name: "六角ナット",           img: "017_20250114_061736_web.webp", specId: "M00000"  },
              { name: "ゆるみ止めナット",     img: "7b-cut_web.webp",              specId: "N08010"  },
              { name: "高ナット",            img: "016_20250114_061736_web.webp",  specId: "N00H00"  },
              { name: "座金",                img: "015_20250114_061736_web.webp",  specId: "W00000"  },
              { name: "小ねじ",              img: "12-cut_web.webp",               specId: "000000"  },
              { name: "木材用",              img: "011_20250114_061736_web.webp",  specId: "600002"  },
              { name: "鉄用ビス",            img: "16a-cut_web.webp",              specId: ""        },
              { name: "あと施工アンカー",     img: "17a-cut_web.webp",             specId: ""        },
              { name: "あと施工アンカー",     img: "17b-cut_web.webp",             specId: ""        },
              { name: "L型アンカー",         img: "009_20250114_061736_web.webp",  specId: "U1L000"  },
              { name: "止め輪",              img: "008_20250114_061736_web.webp",  specId: ""        },
              { name: "ボルト加工品",         img: "007_20250114_061736_web.webp", specId: ""        },
              { name: "曲げ加工品",           img: "item-tool.webp",               specId: ""        },
              { name: "アイボルト",           img: "004_20250114_061736_web.webp", specId: "C00350"  },
              { name: "ゆるみ止めナット",     img: "7a-cut_web.webp",              specId: "N00254"  },
            ].map((item) => (
              <div
                class="border border-gray-200 p-4 flex flex-col items-center justify-between aspect-square bg-white transition-colors relative cursor-pointer hover:border-[#008B9B] group spec-card"
                data-spec-id={item.specId}
                data-name={item.name}
              >
                {item.specId
                  ? <span class="absolute top-1.5 right-1.5 bg-[#008B9B] text-white text-[8px] font-mb101 px-1.5 py-0.5 leading-none z-10">図面・規格</span>
                  : <span class="absolute top-1.5 right-1.5 bg-gray-300 text-white text-[8px] font-mb101 px-1.5 py-0.5 leading-none z-10">準備中</span>
                }
                <div class="flex-grow flex items-center justify-center mb-2 w-full overflow-hidden">
                  <img
                    src={`/images/${item.img}`}
                    alt={item.name}
                    class="max-h-[120px] w-auto object-contain group-hover:scale-105 transition-transform duration-300"
                  />
                </div>
                <span class="text-[11px] font-bold text-gray-700 text-center leading-tight">{item.name}</span>
              </div>
            ))}
          </div>
        </div>

        {/* ===== ライトボックス ===== */}
        <div id="spec-overlay" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/70 backdrop-blur-sm">
          <div id="spec-box" class="bg-white w-full max-w-4xl max-h-[90vh] flex flex-col shadow-2xl overflow-hidden">

            {/* ヘッダー */}
            <div class="flex items-start justify-between px-6 py-4 border-b border-gray-200 flex-shrink-0">
              <div>
                <div id="lb-code" class="text-xs text-[#008B9B] font-mono tracking-widest mb-1"></div>
                <div id="lb-name" class="text-lg font-bold text-gray-900 font-mb101"></div>
              </div>
              <button id="lb-close" class="w-8 h-8 flex items-center justify-center text-gray-400 hover:bg-gray-100 hover:text-gray-700 transition-colors text-xl leading-none">✕</button>
            </div>

            {/* ボディ */}
            <div class="flex flex-1 overflow-hidden">
              <div id="lb-drawing" class="w-60 flex-shrink-0 bg-gray-50 border-r border-gray-200 p-5 flex flex-col gap-3 overflow-y-auto"></div>
              <div id="lb-spec" class="flex-1 overflow-auto p-6"></div>
            </div>

            {/* フッター */}
            <div class="flex items-center justify-between px-6 py-3 border-t border-gray-100 bg-gray-50 flex-shrink-0">
              <span id="lb-footer-code" class="text-xs font-mono text-gray-400"></span>
              <div class="flex items-center gap-4">
                <span class="text-xs font-mono text-gray-400">図面／規格 2026/02/16</span>
                <button id="lb-download" class="inline-flex items-center gap-2 bg-[#008B9B] hover:bg-[#006064] text-white text-xs font-mb101 font-bold px-4 py-2 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v13M7 11l5 5 5-5M5 20h14"/>
                  </svg>
                  <span id="lb-download-label">規格PDFをダウンロード</span>
                </button>
              </div>
            </div>
          </div>
        </div>

        <style>
          #spec-overlay.active { display: flex; }
          .spec-table { width:100%; border-collapse:collapse; font-size:12px; }
          .spec-table th { background:#1a1a18; color:#fff; font-family:monospace; font-size:10px; padding:7px 10px; text-align:center; white-space:nowrap; }
          .spec-table th.th-main { background:#008B9B; }
          .spec-table td { padding:6px 10px; text-align:center; font-family:monospace; font-size:11px; border-bottom:1px solid #eee; }
          .spec-table tr:nth-child(even) td { background:#f9f9f9; }
          .spec-table tr:hover td { background:#e0f5f7; }
          .spec-table td.td-main { font-weight:600; color:#008B9B; background:#f0fafb; }
          .spec-tab-btn { font-size:11px; font-weight:600; padding:4px 12px; border:1px solid #ccc; color:#666; cursor:pointer; transition:all .15s; }
          .spec-tab-btn.active { background:#008B9B; color:#fff; border-color:#008B9B; }
        </style>

        <script>
        // ==========================================
        // 図面SVG（製品タイプ別）
        // ==========================================
        const DRAWINGS = {
          eyebolt: `<svg viewBox="0 0 200 200" style="width:100%;max-height:180px"><circle cx="72" cy="68" r="36" fill="none" stroke="#333" stroke-width="2.5"/><circle cx="72" cy="68" r="21" fill="#e8e8e8" stroke="#333" stroke-width="2"/><line x1="72" y1="32" x2="72" y2="47" stroke="#333" stroke-width="2.5"/><rect x="62" y="100" width="20" height="9" fill="#ccc" stroke="#333" stroke-width="1.5" rx="1"/><rect x="65" y="109" width="14" height="46" fill="#ddd" stroke="#333" stroke-width="1.5"/><line x1="65" y1="119" x2="79" y2="119" stroke="#888" stroke-width="0.8"/><line x1="65" y1="126" x2="79" y2="126" stroke="#888" stroke-width="0.8"/><line x1="65" y1="133" x2="79" y2="133" stroke="#888" stroke-width="0.8"/><line x1="65" y1="140" x2="79" y2="140" stroke="#888" stroke-width="0.8"/><line x1="65" y1="147" x2="79" y2="147" stroke="#888" stroke-width="0.8"/><text x="72" y="10" text-anchor="middle" font-size="9" fill="#008B9B" font-family="monospace">a</text><text x="140" y="130" font-size="9" fill="#008B9B" font-family="monospace">L</text></svg>`,
          nut:     `<svg viewBox="0 0 200 160" style="width:100%;max-height:160px"><polygon points="100,20 136,40 136,88 100,108 64,88 64,40" fill="#ccc" stroke="#444" stroke-width="2.5"/><circle cx="100" cy="64" r="22" fill="#f0f0f0" stroke="#444" stroke-width="2"/><text x="100" y="145" text-anchor="middle" font-size="9" fill="#008B9B" font-family="monospace">s / m</text></svg>`,
          washer:  `<svg viewBox="0 0 200 140" style="width:100%;max-height:140px"><ellipse cx="100" cy="60" rx="72" ry="44" fill="#ccc" stroke="#444" stroke-width="2"/><ellipse cx="100" cy="60" rx="28" ry="17" fill="#f0f0f0" stroke="#444" stroke-width="2"/><text x="100" y="120" text-anchor="middle" font-size="9" fill="#008B9B" font-family="monospace">D / d / t</text></svg>`,
          woodscrew:`<svg viewBox="0 0 220 140" style="width:100%;max-height:140px"><path d="M52,36 L92,36 L84,62 L60,62 Z" fill="#ccc" stroke="#333" stroke-width="1.5"/><line x1="72" y1="38" x2="72" y2="60" stroke="#666" stroke-width="1.5"/><line x1="54" y1="49" x2="90" y2="49" stroke="#666" stroke-width="1.5"/><rect x="67" y="62" width="10" height="52" fill="#ddd" stroke="#333" stroke-width="1.5"/><path d="M67,114 Q72,124 77,114" fill="#aaa" stroke="#333" stroke-width="1"/></svg>`,
          smallscrew:`<svg viewBox="0 0 220 140" style="width:100%;max-height:140px"><ellipse cx="60" cy="38" rx="30" ry="18" fill="#ccc" stroke="#333" stroke-width="1.5"/><line x1="46" y1="35" x2="74" y2="41" stroke="#666" stroke-width="1.5"/><line x1="46" y1="41" x2="74" y2="35" stroke="#666" stroke-width="1.5"/><rect x="56" y="56" width="8" height="56" fill="#ddd" stroke="#333" stroke-width="1.5"/></svg>`,
          socket:  `<svg viewBox="0 0 220 140" style="width:100%;max-height:140px"><polygon points="52,22 80,22 88,36 80,50 52,50 44,36" fill="#ccc" stroke="#444" stroke-width="2"/><polygon points="56,26 76,26 76,38 56,38" fill="#aaa" stroke="#444" stroke-width="1"/><rect x="52" y="50" width="28" height="56" fill="#ddd" stroke="#333" stroke-width="1.5"/></svg>`,
          hex:     `<svg viewBox="0 0 220 140" style="width:100%;max-height:140px"><polygon points="44,20 72,20 80,36 72,52 44,52 36,36" fill="#ccc" stroke="#444" stroke-width="2"/><rect x="44" y="52" width="28" height="56" fill="#ddd" stroke="#333" stroke-width="1.5"/><line x1="44" y1="62" x2="72" y2="62" stroke="#888" stroke-width="0.8"/><line x1="44" y1="72" x2="72" y2="72" stroke="#888" stroke-width="0.8"/><line x1="44" y1="82" x2="72" y2="82" stroke="#888" stroke-width="0.8"/></svg>`,
          ubolt:   `<svg viewBox="0 0 200 160" style="width:100%;max-height:160px"><path d="M56,10 L56,90 Q56,130 100,130 Q144,130 144,90 L144,10" fill="none" stroke="#ccc" stroke-width="14" stroke-linecap="round"/><path d="M56,10 L56,90 Q56,130 100,130 Q144,130 144,90 L144,10" fill="none" stroke="#888" stroke-width="2" stroke-linecap="round"/><rect x="48" y="4" width="16" height="22" fill="#bbb" stroke="#888" stroke-width="1.5" rx="2"/><rect x="136" y="4" width="16" height="22" fill="#bbb" stroke="#888" stroke-width="1.5" rx="2"/></svg>`,
        };

        let PRODUCTS = [];
        let currentProduct = null;
        let currentTabIdx = 0;

        // products.json 読み込み
        fetch('/data/products.json')
          .then(r => r.json())
          .then(data => {
            PRODUCTS = data;
            // 全カードにクリックイベント付与
            document.querySelectorAll('.spec-card').forEach(card => {
              card.addEventListener('click', () => {
                const id = card.dataset.specId;
                const name = card.dataset.name;
                if (id) {
                  const product = PRODUCTS.find(p => p.id === id);
                  if (product) openLightbox(product);
                } else {
                  openPending(name);
                }
              });
            });
          })
          .catch(e => console.error('products.json 読み込み失敗:', e));

        // 規格表準備中ライトボックス
        function openPending(name) {
          currentProduct = null;
          document.getElementById('lb-code').textContent = '準備中';
          document.getElementById('lb-name').textContent = name;
          document.getElementById('lb-footer-code').textContent = '—';
          document.getElementById('lb-drawing').innerHTML = `
            <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:12px;opacity:.4">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#008B9B" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
              </svg>
              <span style="font-size:11px;color:#888;text-align:center;line-height:1.6">図面データ<br>準備中</span>
            </div>
          `;
          document.getElementById('lb-spec').innerHTML = `
            <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:20px;padding:32px;text-align:center">
              <div style="width:64px;height:64px;background:#f0fafb;border-radius:50%;display:flex;align-items:center;justify-content:center">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#008B9B" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <p style="font-size:16px;font-weight:700;color:#1a1a18;margin-bottom:8px">規格表を準備中です</p>
                <p style="font-size:13px;color:#888;line-height:1.8">
                  <strong style="color:#333">${name}</strong> の図面・規格表は<br>
                  現在データを整備中です。<br>
                  今しばらくお待ちください。
                </p>
              </div>
              <div style="margin-top:8px;padding:12px 20px;background:#f8f8f8;border-left:3px solid #008B9B">
                <p style="font-size:12px;color:#666;line-height:1.7">
                  お急ぎの場合はお電話またはメールフォームよりお問合せください。<br>
                  担当者が詳細をご案内いたします。
                </p>
              </div>
              <a href="#inquiry" onclick="closeLightbox()" style="display:inline-flex;align-items:center;gap:6px;background:#008B9B;color:#fff;font-size:12px;font-weight:700;padding:10px 20px;text-decoration:none;transition:background .15s" onmouseover="this.style.background='#006064'" onmouseout="this.style.background='#008B9B'">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
                </svg>
                お問合せはこちら
              </a>
            </div>
          `;
          // ダウンロードボタンを無効化
          const dlBtn = document.getElementById('lb-download');
          dlBtn.disabled = true;
          dlBtn.style.opacity = '0.4';
          dlBtn.style.cursor = 'not-allowed';

          const ov = document.getElementById('spec-overlay');
          ov.classList.remove('hidden');
          ov.classList.add('active');
          document.body.style.overflow = 'hidden';
        }

        // ライトボックスを開く
        function openLightbox(product) {
          currentProduct = product;
          currentTabIdx = 0;
          document.getElementById('lb-code').textContent = product.id;
          document.getElementById('lb-name').textContent = product.name;
          document.getElementById('lb-footer-code').textContent = product.id;

          // ダウンロードボタンを有効化（準備中から戻る場合を考慮）
          const dlBtn = document.getElementById('lb-download');
          dlBtn.disabled = false;
          dlBtn.style.opacity = '1';
          dlBtn.style.cursor = 'pointer';

          // 図面
          const svg = DRAWINGS[product.drawingType] || DRAWINGS.hex;
          document.getElementById('lb-drawing').innerHTML = `
            <div style="font-size:9px;color:#999;letter-spacing:.15em;text-transform:uppercase;margin-bottom:4px">図面</div>
            ${svg}
            <div style="font-size:10px;color:#aaa;line-height:1.7;margin-top:8px">${(product.drawingNote||'').replace(/\n/g,'<br>')}</div>
          `;

          renderSpec(product, 0);

          const ov = document.getElementById('spec-overlay');
          ov.classList.remove('hidden');
          ov.classList.add('active');
          document.body.style.overflow = 'hidden';
        }

        // 規格表レンダリング
        function renderSpec(product, tabIdx) {
          const el = document.getElementById('lb-spec');
          const specs = product.specs;
          let html = '';

          if (specs.length > 1) {
            html += `<div style="display:flex;gap:6px;margin-bottom:14px;flex-wrap:wrap">`;
            specs.forEach((s, i) => {
              html += `<button class="spec-tab-btn${i===tabIdx?' active':''}" onclick="switchSpecTab(${i})">${s.label}</button>`;
            });
            html += `</div>`;
          } else {
            html += `<div style="font-size:10px;color:#999;font-family:monospace;margin-bottom:10px">${specs[0].label}</div>`;
          }

          const spec = specs[tabIdx];
          html += `<div style="overflow-x:auto"><table class="spec-table">`;

          if (spec.headerRows) {
            html += `<thead><tr>`;
            spec.headerRows.forEach(([span,label,isMain]) => {
              html += `<th colspan="${span}" class="${isMain?'th-main':''}">${label}</th>`;
            });
            html += `</tr><tr>`;
            spec.subHeaderRow.forEach((sub,ci) => {
              html += `<th class="${ci===0?'th-main':''}" style="font-size:9px;background:${ci===0?'#008B9B':'#333'}">${sub}</th>`;
            });
            html += `</tr></thead>`;
          } else {
            html += `<thead><tr>`;
            spec.columns.forEach((col,ci) => {
              html += `<th class="${ci===spec.mainCol?'th-main':''}">${col}</th>`;
            });
            html += `</tr></thead>`;
          }

          html += `<tbody>`;
          spec.rows.forEach(row => {
            html += `<tr>`;
            row.forEach((cell,ci) => {
              const isMain = ci === spec.mainCol;
