            await loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js');

            const p = currentProduct;
            const spec = p.specs[currentTabIdx];
            const el = document.createElement('div');
            el.style.cssText = 'position:fixed;left:-9999px;top:0;width:794px;background:#fff;font-family:sans-serif;padding:40px 48px;box-sizing:border-box;';
            el.innerHTML = `
