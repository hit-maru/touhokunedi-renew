---
// src/pages/news/[page].astro
import Layout from '../../layouts/Layout.astro';
import { getNews, client } from '../../lib/microcms';
import { format } from 'date-fns';

const CATEGORIES = ['製品情報', '展示会', 'イベント', 'ニュース'];

export async function getStaticPaths() {
  const PER_PAGE = 10;
  // 全件取得（100件制限を回避）
  const allContents = await client.getAllContents({
    endpoint: 'news',
    queries: {
      fields: 'id,title,date,category,thumbnail',
      orders: '-date'
    }
  });
  const all = { contents: allContents };
  const total = allContents.length;
  const totalPages = Math.ceil(total / PER_PAGE);

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: String(i + 1) },
    props: {
      news: all.contents.slice(i * PER_PAGE, (i + 1) * PER_PAGE),
      totalPages,
      currentPage: i + 1,
      allNews: all.contents,
    },
  }));
}

const { news, totalPages, currentPage, allNews } = Astro.props;

// 年度一覧
const years = [...new Set(
  allNews.map((p: any) => new Date(p.date).getFullYear())
)].sort((a: number, b: number) => b - a);

// ページ番号リスト生成（省略なし・シンプル版）
function getPageNumbers(current: number, total: number): (number | '...')[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const pages: (number | '...')[] = [];
  pages.push(1);
  if (current > 4) pages.push('...');
  for (let i = Math.max(2, current - 2); i <= Math.min(total - 1, current + 2); i++) {
    pages.push(i);
  }
  if (current < total - 3) pages.push('...');
  pages.push(total);
  return pages;
}

const pageNumbers = getPageNumbers(currentPage, totalPages);
---

<Layout title={`お知らせ - ${currentPage}ページ目`}>

  <div class="bg-gray-100 pt-[90px] pb-8 border-b border-gray-200">
    <div class="container mx-auto px-6">
      <h1 class="text-4xl md:text-5xl font-mincho font-bold text-[#008B9B] mb-4">お知らせ</h1>
      <p class="text-gray-500 font-serif tracking-wider uppercase">NEWS</p>
    </div>
  </div>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="flex flex-col lg:flex-row gap-12">

        <!-- メインコンテンツ -->
        <div class="flex-1">

          <!-- カテゴリフィルタ（上部） -->
          <div class="flex flex-wrap gap-2 mb-8">
            <button data-category="" class="category-btn text-xs font-bold px-4 py-2 border border-[#008B9B] bg-[#008B9B] text-white rounded-sm transition-colors">
              すべて
            </button>
            {CATEGORIES.map(cat => (
              <button
                data-category={cat}
                class="category-btn text-xs font-bold px-4 py-2 border border-gray-300 text-gray-600 rounded-sm hover:border-[#008B9B] hover:text-[#008B9B] transition-colors"
              >
                {cat}
              </button>
            ))}
          </div>

          <!-- 記事一覧 -->
          <ul class="border-t border-gray-200" id="news-list">
            {news.map((post: any) => (
              <li
                class="news-item border-b border-gray-200"
                data-category={post.category?.[0] ?? ''}
                data-year={String(new Date(post.date).getFullYear())}
              >
                <a href={`/news/${post.id}`} class="block py-6 group transition-colors hover:bg-gray-50 px-4">
                  <div class="flex flex-col md:flex-row md:items-center gap-4">
                    {post.thumbnail && (
                      <div class="w-full md:w-32 h-20 shrink-0 overflow-hidden rounded-sm bg-gray-100">
                        <img
                          src={post.thumbnail.url}
                          alt={post.title}
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        />
                      </div>
                    )}
                    <div class="flex items-center gap-4 w-48 shrink-0">
                      <time datetime={post.date} class="text-gray-400 font-serif text-sm tracking-tighter">
                        {format(new Date(post.date), 'yyyy.MM.dd')}
                      </time>
                      {post.category && post.category.length > 0 && (
                        <span class="text-[10px] font-bold px-2 py-1 bg-gray-100 text-[#008B9B] rounded-sm uppercase tracking-widest">
                          {post.category[0]}
                        </span>
                      )}
                    </div>
                    <h3 class="text-gray-800 font-sans text-[15px] md:text-[16px] font-bold leading-relaxed group-hover:text-[#E64A19] transition-colors flex-grow">
                      {post.title}
                    </h3>
                    <div class="hidden md:block text-gray-300 group-hover:text-[#E64A19] transform group-hover:translate-x-1 transition-all">
                      →
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>

          <!-- ページネーション -->
          <nav class="mt-12 flex justify-center items-center gap-1" aria-label="ページ送り">
            {currentPage > 1 && (
              <a href={`/news/${currentPage - 1}`} class="w-9 h-9 flex items-center justify-center border border-gray-300 text-gray-600 hover:border-[#008B9B] hover:text-[#008B9B] transition-colors text-sm">
                ‹
              </a>
            )}

            {pageNumbers.map((p) => (
              p === '...'
                ? <span class="w-9 h-9 flex items-center justify-center text-gray-400 text-sm">...</span>
                : <a
                    href={`/news/${p}`}
                    class={`w-9 h-9 flex items-center justify-center border text-sm transition-colors ${
                      p === currentPage
                        ? 'border-[#008B9B] bg-[#008B9B] text-white'
                        : 'border-gray-300 text-gray-600 hover:border-[#008B9B] hover:text-[#008B9B]'
                    }`}
                  >
                    {p}
                  </a>
            ))}

            {currentPage < totalPages && (
              <a href={`/news/${currentPage + 1}`} class="w-9 h-9 flex items-center justify-center border border-gray-300 text-gray-600 hover:border-[#008B9B] hover:text-[#008B9B] transition-colors text-sm">
                ›
              </a>
            )}
          </nav>

        </div>

        <!-- サイドバー -->
        <aside class="lg:w-56 shrink-0">

          <!-- 年度フィルタ -->
          <div class="mb-8">
            <h2 class="text-sm font-bold text-gray-700 mb-3 pb-2 border-b border-gray-200 tracking-wider uppercase">年度で絞り込む</h2>
            <ul class="space-y-1">
              <li>
                <button data-year="" class="year-btn w-full text-left text-sm px-3 py-2 text-[#008B9B] font-bold hover:bg-gray-50 transition-colors">
                  すべての年度
                </button>
              </li>
              {years.map((year: number) => (
                <li>
                  <button
                    data-year={String(year)}
                    class="year-btn w-full text-left text-sm px-3 py-2 text-gray-600 hover:text-[#008B9B] hover:bg-gray-50 transition-colors flex items-center gap-2"
                  >
                    <span class="text-gray-400">›</span>
                    {year}年
                  </button>
                </li>
              ))}
            </ul>
          </div>

          <!-- カテゴリ（サイドバー） -->
          <div>
            <h2 class="text-sm font-bold text-gray-700 mb-3 pb-2 border-b border-gray-200 tracking-wider uppercase">カテゴリ</h2>
            <ul class="space-y-1">
              {CATEGORIES.map(cat => (
                <li>
                  <button
                    data-category={cat}
                    class="category-sidebar-btn w-full text-left text-sm px-3 py-2 text-gray-600 hover:text-[#008B9B] hover:bg-gray-50 transition-colors flex items-center gap-2"
                  >
                    <span class="text-gray-400">›</span>
                    {cat}
                  </button>
                </li>
              ))}
            </ul>
          </div>

        </aside>
      </div>
    </div>
  </section>
</Layout>

<script>
  let activeCategory = '';
  let activeYear = '';

  function filterNews() {
    const items = document.querySelectorAll('.news-item');
    items.forEach(item => {
      const cat = item.getAttribute('data-category') ?? '';
      const year = item.getAttribute('data-year') ?? '';
      const catMatch = !activeCategory || cat === activeCategory;
      const yearMatch = !activeYear || year === activeYear;
      (item as HTMLElement).style.display = catMatch && yearMatch ? '' : 'none';
    });
  }

  document.querySelectorAll('.category-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeCategory = btn.getAttribute('data-category') ?? '';
      document.querySelectorAll('.category-btn').forEach(b => {
        b.classList.remove('bg-[#008B9B]', 'text-white', 'border-[#008B9B]');
        b.classList.add('border-gray-300', 'text-gray-600');
      });
      btn.classList.add('bg-[#008B9B]', 'text-white', 'border-[#008B9B]');
      btn.classList.remove('border-gray-300', 'text-gray-600');
      filterNews();
    });
  });

  document.querySelectorAll('.category-sidebar-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeCategory = btn.getAttribute('data-category') ?? '';
      filterNews();
    });
  });

  document.querySelectorAll('.year-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeYear = btn.getAttribute('data-year') ?? '';
      document.querySelectorAll('.year-btn').forEach(b => {
        b.classList.remove('text-[#008B9B]', 'font-bold');
        b.classList.add('text-gray-600');
      });
      btn.classList.add('text-[#008B9B]', 'font-bold');
      btn.classList.remove('text-gray-600');
      filterNews();
    });
  });
</script>
