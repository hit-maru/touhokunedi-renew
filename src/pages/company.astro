---
// src/pages/company.astro
import Layout from '../layouts/Layout.astro';

import Concept from '../components/company/Concept.astro';
import TopMessage from '../components/company/TopMessage.astro';
import BoltWay from '../components/company/BoltWay.astro';
import Philosophy from '../components/company/Philosophy.astro';
import Outline from '../components/company/Outline.astro';
import SDGs from '../components/company/SDGs.astro';
import Certification from '../components/company/Certification.astro';
import History from '../components/company/History.astro';
import Access from '../components/company/Access.astro';
---

<Layout title="企業情報">
  
  {/* ヒーローエリア：規準統一 ＋ 下余白ツメ (pt-20 pb-8) */}
  <div class="bg-gray-100 pt-[90px] pb-8 border-b border-gray-200">
    <div class="container mx-auto px-6">
      <h1 class="text-4xl md:text-5xl font-mincho font-bold text-[#008B9B] mb-4 text-white" style="color: #008B9B;">企業情報</h1>
      <p class="text-gray-500 font-serif tracking-wider uppercase">COMPANY</p>
    </div>
  </div>

  {/* スティッキーナビゲーション：スマホ最適化仕様 */}
  <div class="sticky top-20 bg-white/95 backdrop-blur z-40 border-b border-gray-100 shadow-sm">
    <div class="container mx-auto w py-3">
      
      {/* 📱 スマホ用：セレクトボックス型 */}
      <div class="md:hidden relative">
        <select 
          onchange="window.location.hash = this.value"
          class="w-full bg-white border border-[#008B9B]/30 text-[#008B9B] text-sm font-bold rounded-sm px-4 py-3 appearance-none focus:outline-none focus:ring-2 focus:ring-[#008B9B] font-mb101"
        >
          <option value="#">メニュー：セクションを選択</option>
          <option value="#concept">コンセプト</option>
          <option value="#message">トップメッセージ</option>
          <option value="#statement">TOHOKU BOLT WAY</option>
          <option value="#philosophy">経営ビジョン</option>
          <option value="#outline">会社概要</option>
          <option value="#sdgs">SDGs（当社の取り組み）</option>
          <option value="#certification">認証・ISO</option>
          <option value="#history">沿革</option>
          <option value="#access">アクセス</option>
        </select>
        <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
          <svg class="w-4 h-4 text-[#008B9B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
          </svg>
        </div>
      </div>

      {/* 💻 PC用：横並びメニュー */}
      <nav class="hidden md:flex flex-row justify-center gap-6 lg:gap-8 text-[13px] font-bold text-gray-500 font-mb101">
        <a href="#concept" class="hover:text-[#008B9B] transition-colors">コンセプト</a>
        <a href="#message" class="hover:text-[#008B9B] transition-colors">メッセージ</a>
        <a href="#statement" class="hover:text-[#008B9B] transition-colors">TOHOKU BOLT WAY</a>
        <a href="#philosophy" class="hover:text-[#008B9B] transition-colors">ビジョン</a>
        <a href="#outline" class="hover:text-[#008B9B] transition-colors">概要</a>
        <a href="#sdgs" class="hover:text-[#008B9B] transition-colors">SDGs</a>
        <a href="#certification" class="hover:text-[#008B9B] transition-colors">認証</a>
        <a href="#history" class="hover:text-[#008B9B] transition-colors">沿革</a>
        <a href="#access" class="hover:text-[#008B9B] transition-colors">アクセス</a>
      </nav>
    </div>
  </div>

  {/* メインコンテンツエリア */}
  <div class="[&>section]:scroll-mt-[10px] md:[&>section]:scroll-mt-[10px]">
    <Concept id="concept" />
    <TopMessage id="message" />
    <BoltWay id="statement" />
    <Philosophy id="philosophy" />
    <Outline id="outline" />
    <SDGs id="sdgs" />
    <Certification id="certification" />
    <History id="history" />
    <Access id="access" />
  </div>

</Layout>