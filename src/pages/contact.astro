---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="お問合せ">
  
  <div class="bg-gray-100 pt-[90px] pb-8 border-b border-gray-200">
    <div class="container mx-auto px-6">
      <h1 class="text-4xl md:text-5xl font-mincho font-bold text-[#008B9B] mb-4">お問合せ</h1>
      <p class="text-gray-500 font-serif tracking-wider uppercase">CONTACT</p>
    </div>
  </div>

  <section class="pt-12 pb-24 bg-white">
    <div class="container mx-auto px-6 max-w-4xl">

      <div id="ai-selection" class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
        
        <div class="flex flex-col gap-4">
          <a href="/ai/t-nedi-manufacture_nb" class="group block py-6 bg-[#008B9B] border-2 border-[#008B9B] rounded-sm text-center hover:bg-white transition-all duration-300 shadow-sm">
            <p class="text-white font-mb101 text-[16px] font-bold leading-tight group-hover:text-black transition-colors duration-300">
              AIチャットボットに<br>聞いてみる
            </p>
          </a>
          <a href="/contact-manufacture" class="block p-4 border-2 border-[#008B9B] rounded-sm text-center hover:bg-[#008B9B] hover:text-white transition-all group shadow-sm hover:shadow-lg flex-grow">
            <div class="text-3xl mb-4">🏭</div>
            <h3 class="text-lg font-bold mb-2 font-mb101">製造の<br>お電話でのお問合せ</h3>
            <p class="text-sm opacity-80 font-sans">特注品・技術相談</p>
          </a>
        </div>

        <div class="flex flex-col gap-4">
          <a href="/ai/t-nedi-sales_nb" class="group block py-6 bg-[#008B9B] border-2 border-[#008B9B] rounded-sm text-center hover:bg-white transition-all duration-300 shadow-sm">
            <p class="text-white font-mb101 text-[16px] font-bold leading-tight group-hover:text-black transition-colors duration-300">
              AIチャットボットに<br>聞いてみる
            </p>
          </a>
          <a href="/contact-sales" class="block p-4 border-2 border-[#E64A19] rounded-sm text-center hover:bg-[#E64A19] hover:text-white transition-all group shadow-sm hover:shadow-lg flex-grow">
            <div class="text-3xl mb-4">📦</div>
            <h3 class="text-lg font-bold mb-2 font-mb101">販売の<br>お電話でのお問合せ</h3>
            <p class="text-sm opacity-80 font-sans">在庫確認・見積もり</p>
          </a>
        </div>

        <div class="flex flex-col gap-4">
          <a href="/ai/t-nedi-recruit_nb" class="group block py-6 bg-[#008B9B] border-2 border-[#008B9B] rounded-sm text-center hover:bg-white transition-all duration-300 shadow-sm">
            <p class="text-white font-mb101 text-[16px] font-bold leading-tight group-hover:text-black transition-colors duration-300">
              AIチャットボットに<br>聞いてみる
            </p>
          </a>
          <a href="/contact-recruit" class="block p-4 border-2 border-[#F5A623] rounded-sm text-center hover:bg-[#F5A623] hover:text-white transition-all group shadow-sm hover:shadow-lg flex-grow">
            <div class="text-3xl mb-4">👥</div>
            <h3 class="text-lg font-bold mb-2 font-mb101">採用の<br>お電話でのお問合せ</h3>
            <p class="text-sm opacity-80 font-sans">エントリー・採用質問</p>
          </a>
        </div>

      </div>

      <div class="border-t border-gray-200 mb-16 relative">
        <span class="absolute left-1/2 -translate-x-1/2 -top-3 bg-white px-4 text-sm text-gray-500 font-sans">または</span>
      </div>

      <div class="bg-gray-50 p-4 md:p-12 border border-gray-200 rounded-sm">
        <h3 class="text-[#008B9B] font-mb101 text-2xl font-bold mb-4 text-center">その他のお問合せ</h3>
        <p class="font-sans text-[14px] text-gray-600 mb-8 leading-relaxed font-medium text-center">
          上記以外のお問合せは、こちらのフォームをご利用ください。<br>
          通常、3営業日以内に担当者よりご連絡いたします。
        </p>


        <a
          href="/ai/t-nedi-general_nb"
          class="group block w-full py-4 mb-12 bg-[#008B9B] border-2 border-[#008B9B] rounded-full text-center hover:bg-white transition-all duration-300 shadow-sm"
          >
          <span class="ja-wrap inline-block whitespace-normal break-keep text-white group-hover:text-gray-900 font-mb101 text-[16px] font-bold">
              AIチャットボットに<wbr>聞いてみる
          </span>
        </a>

        <form id="mail-form" action="https://formspree.io/f/mqeezbva" method="POST" class="space-y-8">
          <div style="display:none;">
            <label>Website</label>
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off">
          </div>
          <div>
            <label for="company" class="block font-sans text-[14px] font-bold text-gray-700 mb-2">
              貴社名 <span class="text-[#E64A19] text-[10px] ml-1">必須</span>
            </label>
            <input type="text" id="company" name="company" placeholder="例）東北ネヂ製造株式会社" class="w-full bg-white border border-gray-300 p-4 font-sans text-[14px] focus:outline-none focus:border-[#008B9B] focus:bg-white transition-colors" required />
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <label for="name" class="block font-sans text-[14px] font-bold text-gray-700 mb-2">
                お名前 <span class="text-[#E64A19] text-[10px] ml-1">必須</span>
              </label>
              <input type="text" id="name" name="name" placeholder="例）東北 太郎" class="w-full bg-white border border-gray-300 p-4 font-sans text-[14px] focus:outline-none focus:border-[#008B9B] focus:bg-white transition-colors" required />
            </div>
            <div>
              <label for="email" class="block font-sans text-[14px] font-bold text-gray-700 mb-2">
                メールアドレス <span class="text-[#E64A19] text-[10px] ml-1">必須</span>
              </label>
              <input type="email" id="email" name="email" placeholder="例）info@touhokunedi.com" class="w-full bg-white border border-gray-300 p-4 font-sans text-[14px] focus:outline-none focus:border-[#008B9B] focus:bg-white transition-colors" required />
            </div>
          </div>

          <div>
            <label for="message" class="block font-sans text-[14px] font-bold text-gray-700 mb-2">
              お問合せ内容 <span class="text-[#E64A19] text-[10px] ml-1">必須</span>
            </label>
            <textarea id="message" name="message" rows="6" placeholder="ご自由にご記入ください" class="w-full bg-white border border-gray-300 p-4 font-sans text-[14px] focus:outline-none focus:border-[#008B9B] focus:bg-white transition-colors" required></textarea>
          </div>

          <div class="text-center pt-8">
            <button type="submit" class="bg-[#008B9B] text-white font-bold w-full md:w-auto md:px-24 py-4 font-mb101 text-[16px] hover:bg-[#006064] transition-all shadow-lg hover:shadow-none translate-y-0 hover:translate-y-1">
              内容を確認して送信する
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

</Layout>