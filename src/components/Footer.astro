---
// src/components/Footer.astro
const today = new Date();

const offices = [
  { 
    label: "本社・工場・いわき営業所・鉄道車両チーム", 
    zip: "〒971-8184", 
    addr: "福島県いわき市泉町黒須野字砂利59番地",
    mapQuery: "福島県いわき市泉町黒須野字砂利59番地"
  },
  { 
    label: "東京本社", 
    zip: "〒110-0015", 
    addr: "東京都台東区東上野1丁目26-2 オーラムビル4F",
    mapQuery: "東京都台東区東上野1丁目26-2 オーラムビル"
  },
  { 
    label: "仙台営業部", 
    zip: "〒983-0043", 
    addr: "宮城県仙台市宮城野区萩野町4-4-35",
    mapQuery: "宮城県仙台市宮城野区萩野町4-4-35"
  },
  { 
    label: "郡山営業所", 
    zip: "〒963-0725", 
    addr: "福島県郡山市田村町金屋字新家99-1",
    mapQuery: "福島県郡山市田村町金屋字新家99-1"
  }
];
---

<footer class="bg-gray-900 text-white pt-20 pb-10 border-t-4 border-[#E64A19]">
  <div class="container mx-auto px-6">

    {/* 上部：ロゴエリア */}
    <div class="mb-8 md:mb-1">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
        <div class="md:col-span-5">
          <p class="font-serif text-5xl tracking-normal leading-none mb-2 text-white">nedzi</p>
          <p class="font-serif text-[12px] tracking-widest text-gray-400 uppercase">Tohoku Bolt Mfg. Co., Ltd.</p>
        </div>
      </div>
    </div>

    {/* 見出し行：スマホでは非表示 */}
    <div class="hidden md:grid grid-cols-1 md:grid-cols-12 gap-12 mb-4">
      <div class="md:col-span-5"></div>
      <div class="md:col-span-2">
        <p class="font-mb101 text-[12px] text-gray-400 tracking-widest uppercase font-bold">Company</p>
      </div>
      <div class="md:col-span-2">
        <p class="font-mb101 text-[12px] text-gray-400 tracking-widest uppercase font-bold">Products</p>
      </div>
      <div class="md:col-span-3">
        <p class="font-mb101 text-[12px] text-gray-400 tracking-widest uppercase font-bold">Contact</p>
      </div>
    </div>

    {/* コンテンツ行 */}
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-16">

      {/* 左ブロック：4拠点情報 */}
      <div class="md:col-span-5">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {offices.map((office) => (
            <div>
              <p class="font-mb101 text-[13px] text-[#008B9B] tracking-widest mb-1 font-bold">
                {office.label}
              </p>
              <a 
                href={`https://www.google.com/maps?q=${encodeURIComponent(office.mapQuery)}`}
                target="_blank" 
                rel="noopener noreferrer"
                class="font-sans text-[13px] text-white leading-snug font-medium hover:underline underline-offset-4 block"
              >
                {office.zip} {office.addr}
              </a>
            </div>
          ))}
        </div>
      </div>

      {/* 中ブロック：COMPANY */}
      <div class="md:col-span-2">
        <p class="font-mb101 text-[12px] text-gray-400 tracking-widest mb-3 uppercase font-bold md:hidden">Company</p>
        <ul class="space-y-3 font-sans text-[14px]">
          <li><a href="/company" class="text-white hover:text-[#008B9B] transition-colors">企業情報トップ</a></li>
          <li><a href="/company#message" class="text-white hover:text-[#008B9B] transition-colors">トップメッセージ</a></li>
          <li><a href="/company#outline" class="text-white hover:text-[#008B9B] transition-colors">会社概要</a></li>
          <li><a href="/company#history" class="text-white hover:text-[#008B9B] transition-colors">会社沿革</a></li>
        </ul>
      </div>

      {/* 中ブロック：PRODUCTS / NEWS */}
      <div class="md:col-span-2 flex flex-col">
        <p class="font-mb101 text-[12px] text-gray-400 tracking-widest mb-3 uppercase font-bold md:hidden">Products</p>
        <ul class="space-y-3 font-sans text-[14px]">
          <li><a href="/manufacture" class="text-white hover:text-[#008B9B] transition-colors">製造事業</a></li>
          <li><a href="/sales" class="text-white hover:text-[#008B9B] transition-colors">販売事業</a></li>
          <li><a href="/news" class="text-white hover:text-[#008B9B] transition-colors">お知らせ</a></li>
        </ul>
        <div class="mt-auto mb-[10px] flex gap-3">
          <a href="https://www.linkedin.com/company/%E6%9D%B1%E5%8C%97%E3%83%8D%E3%83%82%E8%A3%BD%E9%80%A0%EF%BC%88%E6%A0%AA%EF%BC%89/" target="_blank" rel="noopener noreferrer" class="text-white/70 hover:text-white transition-colors" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-[22px] h-[22px]">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/tohokubolt_official/" target="_blank" rel="noopener noreferrer" class="text-white/70 hover:text-white transition-colors" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-[22px] h-[22px]">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      {/* 右ブロック：お問合せ */}
      <div class="md:col-span-3">
        <p class="font-mb101 text-[12px] text-gray-400 tracking-widest mb-3 uppercase font-bold md:hidden">Contact</p>
        <div class="mb-6 space-y-4">
          <div>
            <p class="text-[11px] text-[#008B9B] mb-1 font-sans">本社代表電話</p>
            <a href="tel:0246564751" class="font-serif text-2xl text-white hover:text-[#008B9B] transition-colors">
              0246-56-4751
            </a>
          </div>
          <div>
            <p class="text-[11px] text-[#008B9B] mb-1 font-sans">ねじ製造問合せ</p>
            <a href="tel:0362847130" class="font-serif text-2xl text-white hover:text-[#008B9B] transition-colors">
              03-6284-7130
            </a>
          </div>
        </div>{/* ← mb-6 space-y-4 の閉じ */}
        <a href="/contact#mail-form" class="inline-block border border-white text-white px-6 py-3 text-[12px] font-mb101 font-bold hover:bg-white hover:text-gray-900 transition-all">
          お問合せフォーム →
        </a>
      </div>{/* ← md:col-span-3 の閉じ */}

    </div>{/* ← grid mb-16 の閉じ */}

    {/* コピーライト */}
    <div class="pt-8 border-t border-white/10 text-center flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex gap-6 text-[11px] font-mb101 text-gray-500">
        <a href="/privacy" class="hover:text-white transition-colors">個人情報保護方針</a>
        <a href="/sitemap" class="hover:text-white transition-colors">サイトマップ</a>
      </div>
      <p class="font-serif text-[12px] text-gray-500 tracking-widest">
        &copy; {today.getFullYear()} Tohoku Bolt Mfg. Co., Ltd. All rights reserved.
      </p>
    </div>

  </div>{/* ← container の閉じ */}
</footer>
