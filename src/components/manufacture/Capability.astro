---
// src/components/manufacture/Capability.astro
---
<section id="capability" class="pt-4 md:pt-12 pb-12 bg-white text-gray-900 overflow-hidden">
  <div class="container mx-auto px-6">
    
    <div class="mb-8 md:mb-20">
      <span class="text-[#E64A19] font-serif font-bold tracking-widest text-base mb-4 block uppercase tracking-[0.2em]">Products</span>
      <h2 class="font-mb101 text-4xl md:text-5xl mb-8 border-l-8 border-[#008B9B] pl-6 leading-none">製品紹介</h2>
      <p class="font-sans text-[15px] text-gray-600 leading-relaxed font-medium">
        JIS認定規格の標準製品から、社会インフラの深部を支えるM110超の太径ボルトまで。
        多岐にわたる重要締結部品のラインナップが、あらゆる現場のニーズに応えます。
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8 md:gap-y-20 mb-8 md:mb-32">
      
      <div id="lineup-01" class="group scroll-mt-40">
        <div class="overflow-hidden bg-gray-50 rounded-lg mb-6 shadow-sm border border-gray-100">
          <img src="/images/lineup_01photo.png" alt="鉄道・レール分野" class="js-lb-img cursor-zoom-in w-full h-auto transition-transform duration-700 group-hover:scale-105" data-src="/images/lineup_01photo.png" data-caption="鉄道・レール分野" />
        </div>
        <div class="pl-2 border-l-2 border-[#008B9B]">
          <h4 class="font-bold text-xl mb-1 text-gray-800">鉄道・レール分野</h4>
          <p class="text-sm text-[#008B9B] font-bold mb-3">JIS認定の信頼。日本の動脈を支える締結技術。</p>
          <p class="text-[13px] text-gray-600 leading-relaxed font-medium">レール締結用ボルト、レール用ねじくぎ、TNフックボルト、継目板ボルト、犬くぎ等</p>
        </div>
      </div>

      <div id="lineup-04" class="group scroll-mt-40">
        <div class="overflow-hidden bg-gray-50 rounded-lg mb-6 shadow-sm border border-gray-100">
          <img src="/images/lineup_02photo.png" alt="建築・土木分野" class="js-lb-img cursor-zoom-in w-full h-auto transition-transform duration-700 group-hover:scale-105" data-src="/images/lineup_02photo.png" data-caption="建築・土木分野" />
        </div>
        <div class="pl-2 border-l-2 border-[#008B9B]">
          <h4 class="font-bold text-xl mb-1 text-gray-800">建築・土木分野</h4>
          <p class="text-sm text-[#008B9B] font-bold mb-3">巨大構造物を基礎から支える、見えない信頼。</p>
          <p class="text-[13px] text-gray-600 leading-relaxed font-medium">アンカーボルト、スタッドボルト、タワークレーン用ボルト、トンネル継手部品等</p>
        </div>
      </div>

      <div id="lineup-03" class="group scroll-mt-40">
        <div class="overflow-hidden bg-gray-50 rounded-lg mb-6 shadow-sm border border-gray-100">
          <img src="/images/lineup_03photo.png" alt="エネルギー・プラント分野" class="js-lb-img cursor-zoom-in w-full h-auto transition-transform duration-700 group-hover:scale-105" data-src="/images/lineup_03photo.png" data-caption="エネルギー・プラント分野" />
        </div>
        <div class="pl-2 border-l-2 border-[#008B9B]">
          <h4 class="font-bold text-xl mb-1 text-gray-800">エネルギー・プラント分野</h4>
          <p class="text-sm text-[#008B9B] font-bold mb-3">過酷な環境に耐える、高強度・高品質の証。</p>
          <p class="text-[13px] text-gray-600 leading-relaxed font-medium">風力発電用ボルト、スタッドボルト、植込ボルト、アンカーボルト、ガス管用Ｔ型ボルト等</p>
        </div>
      </div>

      <div id="lineup-02" class="group scroll-mt-40">
        <div class="overflow-hidden bg-gray-50 rounded-lg mb-6 shadow-sm border border-gray-100">
          <img src="/images/lineup_04photo.png" alt="機械部品" class="js-lb-img cursor-zoom-in w-full h-auto transition-transform duration-700 group-hover:scale-105" data-src="/images/lineup_04photo.png" data-caption="機械部品" />
        </div>
        <div class="pl-2 border-l-2 border-[#008B9B]">
          <h4 class="font-bold text-xl mb-1 text-gray-800">機械部品</h4>
          <p class="text-sm text-[#008B9B] font-bold mb-3">精密な設計思想を具現化する、特殊頭部と太径の融合。</p>
          <p class="text-[13px] text-gray-600 leading-relaxed font-medium">六角穴付ボルト、六角ボルト、車輌モーター固定ボルト、NUボルト等</p>
        </div>
      </div>

    </div>

    <!--
      スケールエリア全体
      スマホ: px-0 rounded-none（左右余白ゼロで図を全幅表示）
      PC:     px-8 rounded-[40px]（通常デザイン）
    -->
    <div class="bg-[#f8f9fa] px-0 py-10 md:px-8 md:py-16 md:rounded-[40px] relative overflow-hidden">

      <!-- タイトル・説明・凡例：内側に px-4 をつけてスマホでも読みやすく -->
      <div class="px-4 md:px-0">
        <h3 class="text-center font-mb101 font-bold text-2xl mb-3 text-gray-800">
          径サイズ展開スケール <span class="text-[#008B9B] text-sm ml-2 font-sans font-normal opacity-60">Bolt Diameter Scale</span>
        </h3>

        <p class="text-center text-[12px] text-gray-500 mb-5 font-medium">
          各色帯をタップ／クリックすると該当分野の製品写真へジャンプします
        </p>

        <!--
          凡例
          スマホ: grid 2列（折り返しなし）
          PC:     flex 横1列・中央揃え（タイトルと揃う）
        -->
        <div class="grid grid-cols-2 gap-x-4 gap-y-2 mb-8 md:hidden">
          <button class="scale-legend-btn flex items-center gap-2 hover:opacity-70 transition-opacity" data-scroll-to="lineup-01">
            <span class="inline-block w-4 h-4 flex-shrink-0 rounded-sm border-2 border-[#1976D2] bg-[#1976D2]/10"></span>
            <span class="text-[11px] font-bold text-gray-600 font-mb101 text-left">鉄道・レール分野</span>
          </button>
          <button class="scale-legend-btn flex items-center gap-2 hover:opacity-70 transition-opacity" data-scroll-to="lineup-03">
            <span class="inline-block w-4 h-4 flex-shrink-0 rounded-sm border-2 border-[#2E7D32] bg-[#2E7D32]/10"></span>
            <span class="text-[11px] font-bold text-gray-600 font-mb101 text-left">エネルギー・プラント</span>
          </button>
          <button class="scale-legend-btn flex items-center gap-2 hover:opacity-70 transition-opacity" data-scroll-to="lineup-02">
            <span class="inline-block w-4 h-4 flex-shrink-0 rounded-sm border-2 border-[#E65100] bg-[#E65100]/10"></span>
            <span class="text-[11px] font-bold text-gray-600 font-mb101 text-left">機械部品</span>
          </button>
          <button class="scale-legend-btn flex items-center gap-2 hover:opacity-70 transition-opacity" data-scroll-to="lineup-04">
            <span class="inline-block w-4 h-4 flex-shrink-0 rounded-sm border-2 border-[#795548] bg-[#795548]/10"></span>
            <span class="text-[11px] font-bold text-gray-600 font-mb101 text-left">建設・土木用</span>
          </button>
        </div>

        <!-- PC用凡例：横1列・中央揃え -->
        <div class="hidden md:flex flex-wrap justify-center gap-6 mb-10 text-[12px] font-bold font-mb101">
          <button class="scale-legend-btn flex items-center gap-2 hover:opacity-70 transition-opacity" data-scroll-to="lineup-01">
            <span class="inline-block w-4 h-4 flex-shrink-0 rounded-sm border-2 border-[#1976D2] bg-[#1976D2]/10"></span>
            <span class="text-gray-600">鉄道・レール分野</span>
          </button>
          <button class="scale-legend-btn flex items-center gap-2 hover:opacity-70 transition-opacity" data-scroll-to="lineup-03">
            <span class="inline-block w-4 h-4 flex-shrink-0 rounded-sm border-2 border-[#2E7D32] bg-[#2E7D32]/10"></span>
            <span class="text-gray-600">エネルギー・プラント分野</span>
          </button>
          <button class="scale-legend-btn flex items-center gap-2 hover:opacity-70 transition-opacity" data-scroll-to="lineup-02">
            <span class="inline-block w-4 h-4 flex-shrink-0 rounded-sm border-2 border-[#E65100] bg-[#E65100]/10"></span>
            <span class="text-gray-600">機械部品</span>
          </button>
          <button class="scale-legend-btn flex items-center gap-2 hover:opacity-70 transition-opacity" data-scroll-to="lineup-04">
            <span class="inline-block w-4 h-4 flex-shrink-0 rounded-sm border-2 border-[#795548] bg-[#795548]/10"></span>
            <span class="text-gray-600">建設・土木用</span>
          </button>
        </div>
      </div>

      <!-- 図エリア：スマホは全幅（余白ゼロ）、PCは max-w-5xl mx-auto -->
      <div class="w-full md:max-w-5xl md:mx-auto relative">

        <!-- ベース画像（lightbox無効・js-クラスなし） -->
        <img
          src="/images/lineup_map.svg"
          alt="径サイズ展開スケール M16-M110"
          class="w-full h-auto drop-shadow-sm block select-none"
          draggable="false"
          id="scale-map-img"
        />

        <!-- 青帯：鉄道・レール分野 -->
        <div class="scale-band"
          data-scroll-to="lineup-01"
          data-label="鉄道・レール分野"
          data-color="25,118,210"
          style="position:absolute;left:42.4%;width:15%;top:64.6%;height:29.7%;cursor:pointer;border-radius:4px;border:2px solid transparent;transition:background 0.2s,border-color 0.2s;box-sizing:border-box;-webkit-tap-highlight-color:transparent;"
          role="button" tabindex="0" aria-label="鉄道・レール分野の製品写真へジャンプ"
        ></div>

        <!-- 修正後 -->
        <!-- 緑帯：エネルギー・プラント分野 -->
        <div class="scale-band"
          data-scroll-to="lineup-03"
          data-label="エネルギー・プラント分野"
          data-color="46,125,50"
          style="position:absolute;left:57.4%;width:15.6%;top:22.7%;height:71.6%;cursor:pointer;border-radius:4px;border:2px solid transparent;transition:background 0.2s,border-color 0.2s;box-sizing:border-box;-webkit-tap-highlight-color:transparent;"
          role="button" tabindex="0" aria-label="エネルギー・プラント分野の製品写真へジャンプ"
        ></div>

        <!-- 橙帯：機械部品 -->
        <div class="scale-band"
          data-scroll-to="lineup-02"
          data-label="機械部品"
          data-color="230,81,0"
          style="position:absolute;left:73%;width:12.2%;top:3%;height:92.8%;cursor:pointer;border-radius:4px;border:2px solid transparent;transition:background 0.2s,border-color 0.2s;box-sizing:border-box;-webkit-tap-highlight-color:transparent;"
          role="button" tabindex="0" aria-label="機械部品の製品写真へジャンプ"
        ></div>

        <!-- 茶帯：建設・土木用 -->
        <div class="scale-band"
          data-scroll-to="lineup-04"
          data-label="建設・土木用"
          data-color="121,85,72"
          style="position:absolute;left:85.2%;width:14.5%;top:22.7%;height:65.3%;cursor:pointer;border-radius:4px;border:2px solid transparent;transition:background 0.2s,border-color 0.2s;box-sizing:border-box;-webkit-tap-highlight-color:transparent;"
          role="button" tabindex="0" aria-label="建設・土木用の製品写真へジャンプ"
        ></div>

        <!-- ツールチップ（PCのみ） -->
        <div id="scale-tooltip"
          style="position:absolute;display:none;background:rgba(0,0,0,0.75);color:#fff;font-size:11px;font-weight:bold;padding:4px 10px;border-radius:4px;pointer-events:none;white-space:nowrap;z-index:10;"
        ></div>

      </div>

      <p class="text-center mt-6 md:mt-8 text-[11px] text-gray-400 italic font-medium px-4 md:px-0">
        ※ミリサイズ（M16〜M110）および対応するインチサイズでの製造が可能です。
      </p>
    </div>

  </div>
</section>

<!-- ライトボックス オーバーレイ -->
<div id="img-lb-overlay"
  style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.88);touch-action:none;overflow:hidden;">

  <!-- キャプション -->
  <div id="img-lb-caption"
    style="position:absolute;top:0;left:0;right:0;padding:14px 56px 14px 20px;color:#fff;font-size:13px;font-weight:700;font-family:sans-serif;background:linear-gradient(to bottom,rgba(0,0,0,0.6),transparent);z-index:2;pointer-events:none;"></div>

  <!-- 閉じるボタン -->
  <button id="img-lb-close"
    style="position:absolute;top:10px;right:14px;z-index:3;background:rgba(255,255,255,0.15);border:none;color:#fff;font-size:22px;line-height:1;width:38px;height:38px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;">✕</button>

  <!-- 操作ヒント -->
  <div id="img-lb-hint"
    style="position:absolute;bottom:14px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,0.55);font-size:11px;font-family:sans-serif;white-space:nowrap;pointer-events:none;z-index:2;">
    ドラッグ／スワイプで移動　ホイール／ピンチで拡大縮小
  </div>

  <!-- 画像コンテナ -->
  <div id="img-lb-container" style="position:absolute;inset:0;overflow:hidden;cursor:grab;">
    <img id="img-lb-img" src="" alt=""
      style="position:absolute;transform-origin:0 0;user-select:none;-webkit-user-drag:none;max-width:none;" />
  </div>
</div>

<script>
(function() {
  const overlay   = document.getElementById('img-lb-overlay');
  const container = document.getElementById('img-lb-container');
  const img       = document.getElementById('img-lb-img');
  const caption   = document.getElementById('img-lb-caption');
  const closeBtn  = document.getElementById('img-lb-close');
  const hint      = document.getElementById('img-lb-hint');

  let scale = 1, minScale = 1, maxScale = 8;
  let tx = 0, ty = 0;
  let dragging = false;
  let wasPinching = false;   // ピンチ操作中フラグ
  let lastX = 0, lastY = 0;
  let lastDist = 0;

  // ---------- ユーティリティ ----------
  function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

  function applyTransform() {
    img.style.transform = `translate(${tx}px,${ty}px) scale(${scale})`;
  }

  function clampTranslation() {
    const cw = container.clientWidth;
    const ch = container.clientHeight;
    const iw = img.naturalWidth  * scale;
    const ih = img.naturalHeight * scale;
    const maxTx = Math.max(0, (iw - cw) / 2);
    const maxTy = Math.max(0, (ih - ch) / 2);
    tx = clamp(tx, cw / 2 - iw / 2 - maxTx, cw / 2 - iw / 2 + maxTx);
    ty = clamp(ty, ch / 2 - ih / 2 - maxTy, ch / 2 - ih / 2 + maxTy);
  }

  function resetTransform() {
    const cw = container.clientWidth;
    const ch = container.clientHeight;
    const fw = img.naturalWidth;
    const fh = img.naturalHeight;
    // 画面に収まるscaleを初期値に
    minScale = Math.min(cw / fw, ch / fh, 1);
    scale = minScale;
    tx = (cw - fw * scale) / 2;
    ty = (ch - fh * scale) / 2;
    applyTransform();
  }

  // ---------- ズーム（中心点を固定） ----------
  function zoomAt(cx, cy, factor) {
    const newScale = clamp(scale * factor, minScale, maxScale);
    const ratio = newScale / scale;
    tx = cx - ratio * (cx - tx);
    ty = cy - ratio * (cy - ty);
    scale = newScale;
    clampTranslation();
    applyTransform();
  }

  // ---------- 開閉 ----------
  function open(src, cap) {
    img.src = src;
    caption.textContent = cap;
    overlay.style.display = 'block';
    document.body.style.overflow = 'hidden';
    img.onload = () => { resetTransform(); };
    // すでにキャッシュ済みの場合
    if (img.complete && img.naturalWidth) resetTransform();
    // ヒントを3秒後に消す
    hint.style.opacity = '1';
    setTimeout(() => { hint.style.opacity = '0'; hint.style.transition = 'opacity 0.5s'; }, 3000);
  }

  function close() {
    overlay.style.display = 'none';
    document.body.style.overflow = '';
    img.src = '';
  }

  // ---------- 起動トリガー ----------
  document.querySelectorAll('.js-lb-img').forEach(el => {
    el.addEventListener('click', () => {
      open(el.dataset.src, el.dataset.caption || el.alt);
    });
  });

  closeBtn.addEventListener('click', close);
  overlay.addEventListener('click', e => {
    // 画像本体・閉じるボタン以外の黒背景エリアをクリック/タップしたら閉じる
    const target = e.target;
    if (target === overlay || target === container || target === hint || target === caption) {
      close();
    }
  });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });

  // ---------- マウスドラッグ ----------
  container.addEventListener('mousedown', e => {
    if (e.button !== 0) return;
    dragging = true;
    lastX = e.clientX; lastY = e.clientY;
    container.style.cursor = 'grabbing';
    e.preventDefault();
  });
  window.addEventListener('mousemove', e => {
    if (!dragging) return;
    tx += e.clientX - lastX;
    ty += e.clientY - lastY;
    lastX = e.clientX; lastY = e.clientY;
    clampTranslation();
    applyTransform();
  });
  window.addEventListener('mouseup', () => {
    dragging = false;
    container.style.cursor = 'grab';
  });

  // ---------- ホイールズーム ----------
  container.addEventListener('wheel', e => {
    e.preventDefault();
    const rect = container.getBoundingClientRect();
    const cx = e.clientX - rect.left;
    const cy = e.clientY - rect.top;
    const factor = e.deltaY < 0 ? 1.12 : 1 / 1.12;
    zoomAt(cx, cy, factor);
  }, { passive: false });

  // ---------- タッチ：パン＆ピンチ ----------
  container.addEventListener('touchstart', e => {
    if (e.touches.length === 1) {
      dragging = true;
      wasPinching = false;
      lastX = e.touches[0].clientX;
      lastY = e.touches[0].clientY;
    } else if (e.touches.length === 2) {
      dragging = false;
      wasPinching = true;
      lastDist = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
    }
    e.preventDefault();
  }, { passive: false });

  container.addEventListener('touchmove', e => {
    if (e.touches.length === 1 && dragging) {
      tx += e.touches[0].clientX - lastX;
      ty += e.touches[0].clientY - lastY;
      lastX = e.touches[0].clientX;
      lastY = e.touches[0].clientY;
      clampTranslation();
      applyTransform();
    } else if (e.touches.length === 2) {
      const dist = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
      const rect = container.getBoundingClientRect();
      const cx = (e.touches[0].clientX + e.touches[1].clientX) / 2 - rect.left;
      const cy = (e.touches[0].clientY + e.touches[1].clientY) / 2 - rect.top;
      if (lastDist > 0) zoomAt(cx, cy, dist / lastDist);
      lastDist = dist;
    }
    e.preventDefault();
  }, { passive: false });

  container.addEventListener('touchend', e => {
    const remainingTouches = e.touches.length;

    // ===== 2本指→0本指（ピンチ終了）=====
    if (wasPinching && remainingTouches === 0) {
      wasPinching = false;
      dragging = false;
      lastDist = 0;
      // スケール・位置はそのまま保持。何もしない。
      return;
    }

    // ===== 2本指→1本指（片方だけ離した）=====
    if (remainingTouches === 1) {
      wasPinching = false;
      dragging = true;
      lastDist = 0;
      lastX = e.touches[0].clientX;
      lastY = e.touches[0].clientY;
      return;
    }

    // ===== 1本指→0本指（タップ終了）=====
    dragging = false;
    lastDist = 0;

    const t = e.changedTouches[0];
    const now = Date.now();

    // ダブルタップ：2倍ズーム or リセット
    if (now - lastTap < 300) {
      const rect = container.getBoundingClientRect();
      const cx = t.clientX - rect.left;
      const cy = t.clientY - rect.top;
      if (scale > minScale * 1.5) {
        resetTransform(); // 拡大中ならリセット
      } else {
        zoomAt(cx, cy, 2.5 / scale); // 2.5倍にズーム
      }
      lastTap = 0;
      return;
    }
    lastTap = now;

    // シングルタップ：画像外なら閉じる
    const el = document.elementFromPoint(t.clientX, t.clientY);
    if (el && el !== img) close();
  });

  let lastTap = 0;

  // ---------- ダブルクリックでリセット ----------
  container.addEventListener('dblclick', () => resetTransform());

})();
</script>

<script>
  const tooltip = document.getElementById('scale-tooltip');

  function scrollToTarget(targetId: string) {
    const target = document.getElementById(targetId);
    if (!target) return;
    const top = target.getBoundingClientRect().top + window.scrollY - 160;
    window.scrollTo({ top, behavior: 'smooth' });
  }

  document.querySelectorAll<HTMLElement>('.scale-band').forEach(band => {
    const targetId = band.dataset.scrollTo ?? '';
    const label    = band.dataset.label ?? '';
    const rgb      = band.dataset.color ?? '0,0,0';

    // PC：ホバー
    band.addEventListener('mouseenter', () => {
      band.style.background  = `rgba(${rgb}, 0.18)`;
      band.style.borderColor = `rgba(${rgb}, 0.55)`;
      if (tooltip) {
        tooltip.textContent   = `▶ ${label}`;
        tooltip.style.display = 'block';
      }
    });
    band.addEventListener('mousemove', (e) => {
      if (!tooltip) return;
      const rect = (band.parentElement as HTMLElement).getBoundingClientRect();
      tooltip.style.left = (e.clientX - rect.left + 12) + 'px';
      tooltip.style.top  = (e.clientY - rect.top  - 32) + 'px';
    });
    band.addEventListener('mouseleave', () => {
      band.style.background  = 'transparent';
      band.style.borderColor = 'transparent';
      if (tooltip) tooltip.style.display = 'none';
    });

    // PC：クリック
    band.addEventListener('click', () => scrollToTarget(targetId));

    // スマホ：タッチ
    band.addEventListener('touchstart', () => {
      band.style.background  = `rgba(${rgb}, 0.25)`;
      band.style.borderColor = `rgba(${rgb}, 0.6)`;
    }, { passive: true });
    band.addEventListener('touchend', (e) => {
      e.preventDefault();
      band.style.background  = 'transparent';
      band.style.borderColor = 'transparent';
      scrollToTarget(targetId);
    });

    // キーボード
    band.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); scrollToTarget(targetId); }
    });
  });

  // 凡例ボタン（スマホ・PC両方）
  document.querySelectorAll<HTMLElement>('.scale-legend-btn').forEach(btn => {
    btn.addEventListener('click', () => scrollToTarget(btn.dataset.scrollTo ?? ''));
  });
</script>