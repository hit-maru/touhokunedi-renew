---
// src/components/SpecLightbox.astro
// sales.astro の「取扱カテゴリー」ブロック内に <SpecLightbox /> として配置
---

<!-- 取扱カテゴリー ラベル＋グリッド -->
<div class="bg-gray-100 py-2 text-center mb-4 border border-gray-200">
  <span class="font-mb101 font-bold text-sm tracking-widest text-gray-700">取扱カテゴリー</span>
</div>
<p class="text-center text-gray-400 text-xs mb-6 font-medium">製品カードをクリックすると図面・規格表をご覧いただけます</p>

<!-- カテゴリータブ -->
<div id="spec-tabs" class="flex flex-wrap gap-2 justify-center mb-6"></div>

<!-- 製品グリッド -->
<div id="spec-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4"></div>

<!-- ===============================
  ライトボックス
================================ -->
<div id="spec-overlay" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/70 backdrop-blur-sm">
  <div id="spec-box" class="bg-white rounded-md w-full max-w-4xl max-h-[90vh] flex flex-col shadow-2xl overflow-hidden">

    <!-- ヘッダー -->
    <div class="flex items-start justify-between px-6 py-4 border-b border-gray-200 flex-shrink-0">
      <div>
        <div id="lb-code" class="text-xs text-[#008B9B] font-mono tracking-widest mb-1"></div>
        <div id="lb-name" class="text-lg font-bold text-gray-900"></div>
      </div>
      <button id="lb-close" class="w-8 h-8 flex items-center justify-center rounded-full text-gray-400 hover:bg-gray-100 hover:text-gray-700 transition-colors text-xl leading-none">✕</button>
    </div>

    <!-- ボディ -->
    <div class="flex flex-1 overflow-hidden">
      <!-- 図面パネル -->
      <div id="lb-drawing" class="w-64 flex-shrink-0 bg-gray-50 border-r border-gray-200 p-5 flex flex-col gap-3 overflow-y-auto"></div>
      <!-- 規格表パネル -->
      <div id="lb-spec" class="flex-1 overflow-auto p-6"></div>
    </div>

    <!-- フッター -->
    <div class="flex items-center justify-between px-6 py-3 border-t border-gray-100 bg-gray-50 flex-shrink-0">
      <span id="lb-footer-code" class="text-xs font-mono text-gray-400"></span>
      <div class="flex items-center gap-4">
        <span class="text-xs font-mono text-gray-400">図面／規格 2026/02/16</span>
        <button id="lb-download" class="inline-flex items-center gap-2 bg-[#008B9B] hover:bg-[#00768a] text-white text-xs font-medium px-4 py-2 rounded transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v13M7 11l5 5 5-5M5 20h14"/>
          </svg>
          <span id="lb-download-label">規格PDFをダウンロード</span>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ===============================
  スタイル
================================ -->
<style>
  /* タブ */
  .spec-tab {
    @apply px-4 py-1.5 rounded-full text-xs font-medium border transition-colors cursor-pointer;
    border-color: #008B9B;
    color: #008B9B;
    background: transparent;
  }
  .spec-tab.active {
    background: #008B9B;
    color: white;
  }

  /* 製品カード */
  .spec-card {
    @apply border border-gray-200 p-4 flex flex-col items-center justify-between aspect-square transition-all duration-200 cursor-pointer relative overflow-hidden bg-white;
  }
  .spec-card:hover {
    @apply border-[#008B9B];
  }
  .spec-card-badge {
    @apply absolute top-1.5 right-1.5 bg-[#008B9B] text-white text-[8px] font-mb101 px-1.5 py-0.5 tracking-wide;
  }
  .spec-card-icon {
    @apply flex-grow flex items-center justify-center mb-2;
  }
  .spec-card-name {
    @apply text-[11px] font-bold text-gray-700 text-center leading-tight;
  }

  /* 規格テーブル */
  .spec-table { @apply w-full border-collapse text-xs; }
  .spec-table th {
    @apply bg-gray-800 text-white font-mono text-[10px] px-2.5 py-2 text-center whitespace-nowrap;
  }
  .spec-table th.th-main { @apply bg-[#008B9B]; }
  .spec-table td {
    @apply px-2.5 py-1.5 text-center font-mono text-[11px] border-b border-gray-100;
  }
  .spec-table tr:nth-child(even) td { @apply bg-gray-50; }
  .spec-table tr:hover td { @apply bg-blue-50; }
  .spec-table td.td-main { @apply font-semibold text-[#008B9B] bg-[#f0fafb]; }
  .spec-table tr:hover td.td-main { @apply bg-blue-50; }

  /* タブ切り替えボタン */
  .spec-tab-btn {
    @apply text-xs font-medium px-3 py-1.5 rounded border border-gray-300 text-gray-500 transition-colors cursor-pointer;
  }
  .spec-tab-btn.active {
    @apply bg-[#008B9B] text-white border-[#008B9B];
  }

  /* 図面ノート */
  .lb-drawing-note {
    @apply text-[10px] text-gray-400 leading-relaxed;
  }

  /* オーバーレイ表示 */
  #spec-overlay.active { @apply flex; }
</style>

<!-- ===============================
  スクリプト
================================ -->
<script>
// ==========================================
// SVGアイコン定義（カテゴリ別）
// ==========================================
const ICONS = {
  eyebolt: `<svg viewBox="0 0 80 70" class="w-full h-full"><circle cx="28" cy="24" r="14" fill="none" stroke="#888" stroke-width="2.5"/><circle cx="28" cy="24" r="8" fill="#e8e8e8" stroke="#888" stroke-width="1.5"/><line x1="28" y1="38" x2="28" y2="42" stroke="#888" stroke-width="2.5"/><rect x="22" y="42" width="12" height="5" fill="#bbb" stroke="#888" stroke-width="1.5" rx="1"/><rect x="24.5" y="47" width="7" height="18" fill="#ccc" stroke="#888" stroke-width="1.5"/></svg>`,
  nut:     `<svg viewBox="0 0 80 70" class="w-full h-full"><polygon points="40,8 62,20 62,48 40,60 18,48 18,20" fill="#ccc" stroke="#888" stroke-width="2"/><circle cx="40" cy="34" r="11" fill="#f0f0f0" stroke="#888" stroke-width="2"/></svg>`,
  washer:  `<svg viewBox="0 0 80 70" class="w-full h-full"><ellipse cx="40" cy="35" rx="30" ry="18" fill="#ccc" stroke="#888" stroke-width="2"/><ellipse cx="40" cy="35" rx="12" ry="7" fill="#f0f0f0" stroke="#888" stroke-width="2"/></svg>`,
  woodscrew:`<svg viewBox="0 0 80 70" class="w-full h-full"><ellipse cx="22" cy="18" rx="16" ry="10" fill="#ccc" stroke="#888" stroke-width="1.5"/><line x1="14" y1="16" x2="30" y2="20" stroke="#666" stroke-width="1.5"/><line x1="14" y1="20" x2="30" y2="16" stroke="#666" stroke-width="1.5"/><rect x="19" y="28" width="6" height="30" fill="#ddd" stroke="#888" stroke-width="1.5"/><path d="M19,58 Q22,66 25,58" fill="#aaa" stroke="#888" stroke-width="1"/></svg>`,
  smallscrew:`<svg viewBox="0 0 80 70" class="w-full h-full"><ellipse cx="22" cy="18" rx="14" ry="9" fill="#ccc" stroke="#888" stroke-width="1.5"/><line x1="14" y1="16" x2="30" y2="20" stroke="#666" stroke-width="1.5"/><line x1="14" y1="20" x2="30" y2="16" stroke="#666" stroke-width="1.5"/><rect x="19.5" y="27" width="5" height="32" fill="#ddd" stroke="#888" stroke-width="1.5"/><line x1="19.5" y1="34" x2="24.5" y2="34" stroke="#999" stroke-width="0.8"/><line x1="19.5" y1="39" x2="24.5" y2="39" stroke="#999" stroke-width="0.8"/><line x1="19.5" y1="44" x2="24.5" y2="44" stroke="#999" stroke-width="0.8"/><line x1="19.5" y1="49" x2="24.5" y2="49" stroke="#999" stroke-width="0.8"/><line x1="19.5" y1="54" x2="24.5" y2="54" stroke="#999" stroke-width="0.8"/></svg>`,
  socket:  `<svg viewBox="0 0 80 70" class="w-full h-full"><polygon points="36,8 50,8 50,16 36,16" fill="#ccc" stroke="#888" stroke-width="1.5"/><rect x="34" y="16" width="12" height="38" fill="#ddd" stroke="#888" stroke-width="1.5"/><polygon points="38,10 48,10 47,16 39,16" fill="#aaa"/></svg>`,
  hex:     `<svg viewBox="0 0 80 70" class="w-full h-full"><polygon points="28,10 46,10 52,20 46,30 28,30 22,20" fill="#ccc" stroke="#888" stroke-width="1.5"/><rect x="28" y="30" width="18" height="28" fill="#ddd" stroke="#888" stroke-width="1.5"/><line x1="28" y1="36" x2="46" y2="36" stroke="#999" stroke-width="0.8"/><line x1="28" y1="42" x2="46" y2="42" stroke="#999" stroke-width="0.8"/><line x1="28" y1="48" x2="46" y2="48" stroke="#999" stroke-width="0.8"/></svg>`,
  ubolt:   `<svg viewBox="0 0 80 70" class="w-full h-full"><path d="M22,8 L22,44 Q22,60 37,60 Q52,60 52,44 L52,8" fill="none" stroke="#ccc" stroke-width="9" stroke-linecap="round"/><path d="M22,8 L22,44 Q22,60 37,60 Q52,60 52,44 L52,8" fill="none" stroke="#888" stroke-width="2" stroke-linecap="round"/><rect x="17" y="4" width="8" height="12" fill="#bbb" stroke="#888" stroke-width="1.5" rx="1"/><rect x="49" y="4" width="8" height="12" fill="#bbb" stroke="#888" stroke-width="1.5" rx="1"/></svg>`,
};

const ICON_MAP = {
  eyebolt: 'eyebolt', nut: 'nut', washer: 'washer',
  woodscrew: 'woodscrew', smallscrew: 'smallscrew',
  socket: 'socket', hex: 'hex', ubolt: 'ubolt',
};

// ==========================================
// 図面SVG（製品タイプ別）
// ==========================================
const DRAWINGS = {
  eyebolt: `<svg viewBox="0 0 200 200" class="w-full" style="max-height:180px"><circle cx="72" cy="68" r="36" fill="none" stroke="#333" stroke-width="2.5"/><circle cx="72" cy="68" r="21" fill="#e8e8e8" stroke="#333" stroke-width="2"/><line x1="72" y1="32" x2="72" y2="47" stroke="#333" stroke-width="2.5"/><rect x="62" y="100" width="20" height="9" fill="#ccc" stroke="#333" stroke-width="1.5" rx="1"/><rect x="65" y="109" width="14" height="46" fill="#ddd" stroke="#333" stroke-width="1.5"/><line x1="65" y1="119" x2="79" y2="119" stroke="#888" stroke-width="0.8"/><line x1="65" y1="126" x2="79" y2="126" stroke="#888" stroke-width="0.8"/><line x1="65" y1="133" x2="79" y2="133" stroke="#888" stroke-width="0.8"/><line x1="65" y1="140" x2="79" y2="140" stroke="#888" stroke-width="0.8"/><line x1="65" y1="147" x2="79" y2="147" stroke="#888" stroke-width="0.8"/><text x="72" y="10" text-anchor="middle" font-size="9" fill="#008B9B" font-family="monospace">a</text><text x="140" y="130" font-size="9" fill="#008B9B" font-family="monospace">L</text><text x="72" y="58" text-anchor="middle" font-size="8" fill="#555" font-family="monospace">b</text></svg>`,
  nut: `<svg viewBox="0 0 200 160" class="w-full" style="max-height:160px"><polygon points="100,20 136,40 136,88 100,108 64,88 64,40" fill="#ccc" stroke="#444" stroke-width="2.5"/><circle cx="100" cy="64" r="22" fill="#f0f0f0" stroke="#444" stroke-width="2"/><text x="100" y="145" text-anchor="middle" font-size="9" fill="#008B9B" font-family="monospace">s / m</text></svg>`,
  washer: `<svg viewBox="0 0 200 140" class="w-full" style="max-height:140px"><ellipse cx="100" cy="60" rx="72" ry="44" fill="#ccc" stroke="#444" stroke-width="2"/><ellipse cx="100" cy="60" rx="28" ry="17" fill="#f0f0f0" stroke="#444" stroke-width="2"/><text x="100" y="120" text-anchor="middle" font-size="9" fill="#008B9B" font-family="monospace">D / d / t</text></svg>`,
  woodscrew: `<svg viewBox="0 0 220 140" class="w-full" style="max-height:140px"><path d="M52,36 L92,36 L84,62 L60,62 Z" fill="#ccc" stroke="#333" stroke-width="1.5"/><line x1="72" y1="38" x2="72" y2="60" stroke="#666" stroke-width="1.5"/><line x1="54" y1="49" x2="90" y2="49" stroke="#666" stroke-width="1.5"/><rect x="67" y="62" width="10" height="52" fill="#ddd" stroke="#333" stroke-width="1.5"/><path d="M67,114 Q72,124 77,114" fill="#aaa" stroke="#333" stroke-width="1"/><line x1="67" y1="72" x2="77" y2="72" stroke="#888" stroke-width="0.8"/><line x1="67" y1="80" x2="77" y2="80" stroke="#888" stroke-width="0.8"/><line x1="67" y1="88" x2="77" y2="88" stroke="#888" stroke-width="0.8"/><line x1="67" y1="96" x2="77" y2="96" stroke="#888" stroke-width="0.8"/><line x1="67" y1="104" x2="77" y2="104" stroke="#888" stroke-width="0.8"/><text x="72" y="136" text-anchor="middle" font-size="9" fill="#008B9B" font-family="monospace">dk / d / ℓ</text></svg>`,
  smallscrew: `<svg viewBox="0 0 220 140" class="w-full" style="max-height:140px"><ellipse cx="60" cy="38" rx="30" ry="18" fill="#ccc" stroke="#333" stroke-width="1.5"/><line x1="46" y1="35" x2="74" y2="41" stroke="#666" stroke-width="1.5"/><line x1="46" y1="41" x2="74" y2="35" stroke="#666" stroke-width="1.5"/><rect x="56" y="56" width="8" height="56" fill="#ddd" stroke="#333" stroke-width="1.5"/><line x1="56" y1="64" x2="64" y2="64" stroke="#888" stroke-width="0.8"/><line x1="56" y1="72" x2="64" y2="72" stroke="#888" stroke-width="0.8"/><line x1="56" y1="80" x2="64" y2="80" stroke="#888" stroke-width="0.8"/><line x1="56" y1="88" x2="64" y2="88" stroke="#888" stroke-width="0.8"/><line x1="56" y1="96" x2="64" y2="96" stroke="#888" stroke-width="0.8"/><text x="72" y="130" text-anchor="middle" font-size="9" fill="#008B9B" font-family="monospace">dk / k / ℓ</text></svg>`,
  socket: `<svg viewBox="0 0 220 140" class="w-full" style="max-height:140px"><polygon points="52,22 80,22 88,36 80,50 52,50 44,36" fill="#ccc" stroke="#444" stroke-width="2"/><polygon points="56,26 76,26 76,38 56,38" fill="#aaa" stroke="#444" stroke-width="1"/><rect x="52" y="50" width="28" height="56" fill="#ddd" stroke="#333" stroke-width="1.5"/><line x1="52" y1="60" x2="80" y2="60" stroke="#888" stroke-width="0.8"/><line x1="52" y1="70" x2="80" y2="70" stroke="#888" stroke-width="0.8"/><line x1="52" y1="80" x2="80" y2="80" stroke="#888" stroke-width="0.8"/><text x="80" y="125" text-anchor="middle" font-size="9" fill="#008B9B" font-family="monospace">dk / k / S</text></svg>`,
  hex: `<svg viewBox="0 0 220 140" class="w-full" style="max-height:140px"><polygon points="44,20 72,20 80,36 72,52 44,52 36,36" fill="#ccc" stroke="#444" stroke-width="2"/><rect x="44" y="52" width="28" height="56" fill="#ddd" stroke="#333" stroke-width="1.5"/><line x1="44" y1="62" x2="72" y2="62" stroke="#888" stroke-width="0.8"/><line x1="44" y1="72" x2="72" y2="72" stroke="#888" stroke-width="0.8"/><line x1="44" y1="82" x2="72" y2="82" stroke="#888" stroke-width="0.8"/><line x1="44" y1="92" x2="72" y2="92" stroke="#888" stroke-width="0.8"/><text x="80" y="125" text-anchor="middle" font-size="9" fill="#008B9B" font-family="monospace">s / k / L</text></svg>`,
  ubolt: `<svg viewBox="0 0 200 160" class="w-full" style="max-height:160px"><path d="M56,10 L56,90 Q56,130 100,130 Q144,130 144,90 L144,10" fill="none" stroke="#ccc" stroke-width="14" stroke-linecap="round"/><path d="M56,10 L56,90 Q56,130 100,130 Q144,130 144,90 L144,10" fill="none" stroke="#888" stroke-width="2" stroke-linecap="round"/><rect x="48" y="4" width="16" height="22" fill="#bbb" stroke="#888" stroke-width="1.5" rx="2"/><rect x="136" y="4" width="16" height="22" fill="#bbb" stroke="#888" stroke-width="1.5" rx="2"/><text x="100" y="152" text-anchor="middle" font-size="9" fill="#008B9B" font-family="monospace">P / H / E</text></svg>`,
};

// ==========================================
// メイン処理
// ==========================================
let PRODUCTS = [];
let currentProduct = null;
let currentTabIdx = 0;
let currentCat = 'all';

async function init() {
  try {
    // products.jsonをfetch（Astroのpublicディレクトリから）
    const res = await fetch('/data/products.json');
    PRODUCTS = await res.json();
  } catch(e) {
    console.error('products.json の読み込みに失敗しました:', e);
    return;
  }
  buildTabs();
  buildGrid('all');
}

// カテゴリータブ生成
function buildTabs() {
  const cats = ['all', ...new Set(PRODUCTS.map(p => p.category))];
  const tabEl = document.getElementById('spec-tabs');
  tabEl.innerHTML = cats.map(c => `
    <button class="spec-tab ${c === 'all' ? 'active' : ''}" data-cat="${c}">
      ${c === 'all' ? 'すべて' : c}
    </button>
  `).join('');
  tabEl.querySelectorAll('.spec-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      tabEl.querySelectorAll('.spec-tab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentCat = btn.dataset.cat;
      buildGrid(currentCat);
    });
  });
}

// グリッド生成
function buildGrid(cat) {
  const filtered = cat === 'all' ? PRODUCTS : PRODUCTS.filter(p => p.category === cat);
  const grid = document.getElementById('spec-grid');
  grid.innerHTML = filtered.map(p => `
    <div class="spec-card" data-id="${p.id}">
      <div class="spec-card-badge">図面・規格</div>
      <div class="spec-card-icon">${ICONS[ICON_MAP[p.drawingType]] || ICONS.hex}</div>
      <div class="spec-card-name">${p.name}</div>
    </div>
  `).join('');
  grid.querySelectorAll('.spec-card').forEach(card => {
    card.addEventListener('click', () => {
      const product = PRODUCTS.find(p => p.id === card.dataset.id);
      if (product) openLightbox(product);
    });
  });
}

// ライトボックスを開く
function openLightbox(product) {
  currentProduct = product;
  currentTabIdx = 0;

  document.getElementById('lb-code').textContent = product.id;
  document.getElementById('lb-name').textContent = product.name;
  document.getElementById('lb-footer-code').textContent = product.id;

  // 図面
  const drawingEl = document.getElementById('lb-drawing');
  const svg = DRAWINGS[product.drawingType] || DRAWINGS.hex;
  drawingEl.innerHTML = `
    <div class="text-[9px] text-gray-400 font-mono tracking-widest uppercase mb-1">図面</div>
    ${svg}
    <div class="lb-drawing-note mt-2">${(product.drawingNote || '').replace(/\n/g,'<br>')}</div>
  `;

  renderSpec(product, 0);

  const overlay = document.getElementById('spec-overlay');
  overlay.classList.remove('hidden');
  overlay.classList.add('active');
  document.body.style.overflow = 'hidden';
}

// 規格表レンダリング
function renderSpec(product, tabIdx) {
  const el = document.getElementById('lb-spec');
  const specs = product.specs;
  let html = '';

  // タブ切り替え（複数材質など）
  if (specs.length > 1) {
    html += `<div class="flex gap-2 mb-4 flex-wrap">`;
    specs.forEach((s, i) => {
      html += `<button class="spec-tab-btn ${i === tabIdx ? 'active' : ''}" onclick="switchSpecTab(${i})">${s.label}</button>`;
    });
    html += `</div>`;
  } else {
    html += `<div class="text-[11px] text-gray-400 font-mono mb-3">${specs[0].label}</div>`;
  }

  const spec = specs[tabIdx];
  html += `<div class="overflow-x-auto"><table class="spec-table">`;

  // ヘッダー（2段 or 1段）
  if (spec.headerRows) {
    html += `<thead><tr>`;
    spec.headerRows.forEach(([span, label, isMain]) => {
      html += `<th colspan="${span}" class="${isMain ? 'th-main' : ''}">${label}</th>`;
    });
    html += `</tr><tr>`;
    spec.subHeaderRow.forEach((sub, ci) => {
      html += `<th class="${ci === 0 ? 'th-main' : ''} text-[9px] bg-gray-700">${sub}</th>`;
    });
    html += `</tr></thead>`;
  } else {
    html += `<thead><tr>`;
    spec.columns.forEach((col, ci) => {
      html += `<th class="${ci === spec.mainCol ? 'th-main' : ''}">${col}</th>`;
    });
    html += `</tr></thead>`;
  }

  html += `<tbody>`;
  spec.rows.forEach(row => {
    html += `<tr>`;
    row.forEach((cell, ci) => {
      const isMain = ci === spec.mainCol;
      const cellStr = String(cell === null || cell === undefined ? '−' : cell).replace(/\n/g,'<br>');
      html += `<td class="${isMain ? 'td-main' : ''}">${cellStr}</td>`;
    });
    html += `</tr>`;
  });
  html += `</tbody></table></div>`;

  if (spec.note) {
    html += `<div class="mt-3 text-[10px] text-gray-500 leading-relaxed bg-gray-50 border-l-2 border-gray-300 px-3 py-2">${spec.note.replace(/\n/g,'<br>')}</div>`;
  }

  el.innerHTML = html;
}

// タブ切り替え（グローバルに公開）
window.switchSpecTab = function(idx) {
  currentTabIdx = idx;
  renderSpec(currentProduct, idx);
};

// ==========================================
// PDF生成
// ==========================================
document.getElementById('lb-download').addEventListener('click', async () => {
  const btn = document.getElementById('lb-download');
  const label = document.getElementById('lb-download-label');
  btn.disabled = true;
  label.textContent = '生成中...';

  try {
    await loadScript('https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js');
    await loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js');

    const p = currentProduct;
    const spec = p.specs[currentTabIdx];

    const printEl = document.createElement('div');
    printEl.style.cssText = 'position:fixed;left:-9999px;top:0;width:794px;background:#fff;font-family:sans-serif;color:#1a1a18;padding:40px 48px;box-sizing:border-box;';

    printEl.innerHTML = `
      <div style="display:flex;align-items:center;justify-content:space-between;border-bottom:2px solid #1a1a18;padding-bottom:12px;margin-bottom:20px">
        <div><div style="font-size:15px;font-weight:700">東北ネジ製造株式会社</div><div style="font-size:9px;color:#666">ISO9001/14001/45001認証取得</div></div>
        <div style="text-align:right"><div style="font-size:9px;color:#008B9B;font-family:monospace">図面／規格</div><div style="font-size:9px;color:#888;font-family:monospace">2026/02/16</div></div>
      </div>
      <div style="margin-bottom:16px">
        <div style="font-size:9px;color:#008B9B;font-family:monospace;letter-spacing:.15em;margin-bottom:4px">${p.id}</div>
        <div style="font-size:20px;font-weight:700;margin-bottom:6px">${p.name}</div>
        ${spec.label ? `<span style="background:#e0f5f7;color:#008B9B;font-size:10px;padding:2px 10px;border-radius:3px">${spec.label}</span>` : ''}
      </div>
      ${buildPdfTable(spec)}
      ${spec.note ? `<div style="margin-top:14px;font-size:9px;color:#555;line-height:1.9;padding:8px 12px;background:#f8f8f8;border-left:3px solid #ccc">${spec.note.replace(/\n/g,'<br>')}</div>` : ''}
      <div style="margin-top:28px;padding-top:10px;border-top:1px solid #ddd;display:flex;justify-content:space-between">
        <div style="font-size:8px;color:#aaa;font-family:monospace">${p.id} — 東北ネジ製造株式会社</div>
        <div style="font-size:8px;color:#aaa;font-family:monospace">tohoku-bolt.co.jp</div>
      </div>
    `;
    document.body.appendChild(printEl);

    const canvas = await html2canvas(printEl, { scale: 2, useCORS: true, backgroundColor: '#ffffff', logging: false });
    document.body.removeChild(printEl);

    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
    const pageW = pdf.internal.pageSize.getWidth();
    const pageH = pdf.internal.pageSize.getHeight();
    const margin = 10;
    const imgW = pageW - margin * 2;
    const imgH = (canvas.height / canvas.width) * imgW;

    let remainH = imgH, srcY = 0, yPos = margin;
    while (remainH > 0) {
      const sliceH = Math.min(remainH, pageH - margin * 2);
      const sc = document.createElement('canvas');
      sc.width = canvas.width;
      sc.height = (sliceH / imgW) * canvas.width;
      sc.getContext('2d').drawImage(canvas, 0, srcY * (canvas.width / imgW), canvas.width, sc.height, 0, 0, sc.width, sc.height);
      pdf.addImage(sc.toDataURL('image/png'), 'PNG', margin, yPos, imgW, sliceH);
      remainH -= sliceH; srcY += sliceH;
      if (remainH > 0) { pdf.addPage(); yPos = margin; }
    }
    pdf.save(`${p.id}_${p.name}${spec.label ? '_' + spec.label : ''}.pdf`);

  } catch(err) {
    console.error('PDF生成エラー:', err);
    alert('PDF生成に失敗しました。');
  }

  btn.disabled = false;
  label.textContent = '規格PDFをダウンロード';
});

function buildPdfTable(spec) {
  const th = (isMain) => `background:${isMain?'#008B9B':'#1a1a18'};color:#fff;font-size:9px;font-family:monospace;padding:7px 10px;text-align:center;white-space:nowrap;border:1px solid #fff`;
  const td = (i, isMain) => `padding:6px 10px;text-align:center;font-family:monospace;font-size:10px;border:1px solid #ddd;background:${isMain?(i%2===0?'#e0f5f7':'#d0eef0'):(i%2===0?'#fff':'#f9f9f9')};${isMain?'font-weight:600;color:#008B9B':''}`;

  let html = `<table style="width:100%;border-collapse:collapse">`;
  if (spec.headerRows) {
    html += '<thead><tr>';
    spec.headerRows.forEach(([span,lbl,isMain]) => { html += `<th colspan="${span}" style="${th(isMain)}">${lbl}</th>`; });
    html += '</tr><tr>';
    spec.subHeaderRow.forEach((sub,ci) => { html += `<th style="${th(ci===0)} font-size:8px;background:${ci===0?'#008B9B':'#333'}">${sub}</th>`; });
    html += '</tr></thead>';
  } else {
    html += '<thead><tr>';
    spec.columns.forEach((col,ci) => { html += `<th style="${th(ci===spec.mainCol)}">${col}</th>`; });
    html += '</tr></thead>';
  }
  html += '<tbody>';
  spec.rows.forEach((row,ri) => {
    html += '<tr>';
    row.forEach((cell,ci) => {
      const isMain = ci === spec.mainCol;
      const val = String(cell === null || cell === undefined ? '−' : cell).replace(/\n/g,'<br>');
      html += `<td style="${td(ri,isMain)}">${val}</td>`;
    });
    html += '</tr>';
  });
  html += '</tbody></table>';
  return html;
}

function loadScript(src) {
  return new Promise((res, rej) => {
    if (document.querySelector(`script[src="${src}"]`)) return res();
    const s = document.createElement('script');
    s.src = src; s.onload = res; s.onerror = rej;
    document.head.appendChild(s);
  });
}

// ==========================================
// 閉じる処理
// ==========================================
function closeLightbox() {
  const overlay = document.getElementById('spec-overlay');
  overlay.classList.add('hidden');
  overlay.classList.remove('active');
  document.body.style.overflow = '';
}

document.getElementById('lb-close').addEventListener('click', closeLightbox);
document.getElementById('spec-overlay').addEventListener('click', (e) => {
  if (e.target === document.getElementById('spec-overlay')) closeLightbox();
});
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

// 起動
init();
</script>
