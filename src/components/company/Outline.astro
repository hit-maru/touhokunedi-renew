---
// src/components/company/Outline.astro
const outlineData = [
  { label: "会社名", value: "東北ネヂ製造株式会社" },
  { label: "創業", value: "昭和18年10月18日" },
  { label: "会社設立", value: "昭和25年9月16日" },
  { label: "代表者", value: "代表取締役社長　関口 龍一郎" },
  { label: "所在地", value: "〒971-8184 福島県いわき市泉町黒須野字砂利59番地" },
  { label: "資本金", value: "1,800万円" },
  { 
    label: "取扱品目", 
    isList: true,
    items: [
      { category: "鉄道・レール分野", text: "レール締結用ボルト、レール用ねじくぎ、TNフックボルト、継目板ボルト、犬くぎ等" },
      { category: "建設・土木分野", text: "アンカーボルト、スタッドボルト、タワークレーン用ボルト、トンネル継手部品等" },
      { category: "エネルギー・プラント分野", text: "風力発電用ボルト、スタッドボルト、植込ボルト、アンカーボルト、ガス管用Ｔ型ボルト等" },
      { category: "機械部品", text: "六角穴付ボルト、六角ボルト、車輌モーター固定ボルト、NUボルト等" }
    ]
  },
  { 
    label: "事業所", 
    isList: true,
    items: [
      { category: "本社", text: "福島県いわき市泉町黒須野字砂利59番地", hash: "#access-main" },
      { category: "東京本社・東京営業部", text: "東京都台東区東上野1丁目26-2 オーラムビル4F", hash: "#access-tokyo" },
      { category: "郡山営業所", text: "福島県郡山市田村町金屋字新家99-1", hash: "#access-koriyama" },
      { category: "仙台営業部", text: "宮城県仙台市宮城野区萩野町4-4-35", hash: "#access-sendai" }
    ]
  },
  { label: "取扱材質", value: "SS、SC、SCM、SNCM、SUS全般、その他合金鋼" },
];
---

<section id="outline" class="py-10 bg-white border-t border-gray-100">
  <div class="container mx-auto px-4 max-w-5xl">
    <div class="mb-10 text-primary">
      <h2 class="font-mb101 text-2xl font-bold flex items-center gap-4">
        <span class="w-1.5 h-6 bg-accent"></span>企業概要
      </h2>
    </div>

    <div class="border border-gray-200 shadow-sm overflow-hidden">
      <dl class="divide-y divide-gray-100">
        {outlineData.map((item) => (
          <div class="flex flex-col md:flex-row border-b border-gray-100 last:border-0">
            <dt class="bg-gray-50 py-4 px-4 md:w-[220px] shrink-0 flex items-start md:items-center">
              <span class="font-mb101 font-bold text-ink text-[14px]">
                {item.label}
              </span>
            </dt>
            
            <dd class="bg-white py-4 px-4 w-full">
              {!item.isList ? (
                <span class="font-sans text-[14px] text-ink font-medium leading-relaxed">
                  {item.value}
                </span>
              ) : (
                <div class="space-y-6">
                  {item.items?.map(sub => (
                    <div class="flex flex-col gap-1.5">
                      <span class="font-mb101 text-[14px] text-primary font-bold">
                        [{sub.category}]
                      </span>
                      {sub.hash ? (
                        <a 
                          href={`/company${sub.hash}`} 
                          class="group inline-block font-sans text-[14px] text-ink leading-relaxed font-medium hover:text-primary transition-colors"
                        >
                          <span class="border-b border-gray-300 group-hover:border-primary">
                            {sub.text}
                          </span>
                        </a>
                      ) : (
                        <p class="font-sans text-[14px] text-ink leading-relaxed font-medium">
                          {sub.text}
                        </p>
                      )}
                    </div>
                  ))}
                </div>
              )}
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</section>