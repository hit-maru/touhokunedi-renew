---
// src/components/company/SDGs.astro
const sdgsItems = [
  { id: 3, text:"インフルエンザ\n予防接種補助・\nAED設置" },
  { id: 4, text:"社内外での教育推進\nQC活動・合知合力・\n安全・資格取得講習\n技能実習生の育成" },
  { id: 5, text:"働きやすい\n職場環境の構築\n女性、高齢者の\n活躍推進" },
  { id: 7, text:"風力発電分野への\n参入・LED化" },
  { id: 8, text:"新分野参入で\n雇用創出\n（風力・廃炉・\n再エネ）" },
  { id: 9, text:"社会インフラへの\n貢献（技術開発・\nねじラボ）" },
  { id: 10, text:"サステナブル調達\nTOHOKU BOLT WAY" },
  { id: 11, text:"地域貢献活動\n（海岸・拠点\n近隣清掃）" },
  { id: 12, text:"持続可能な\n事業環境の構築\n（BCP策定）" },
  { id: 13, text:"CO2排出量\n削減目標2%\n最新設備の導入で\n省エネ対策(GX)" }
];
---

<section id="sdgs" class="py-10 bg-white border-t border-gray-50">
  <div class="container mx-auto px-4 max-w-5xl">
    
    <div class="text-center mb-20">
      <h2 class="font-serif text-3xl md:text-4xl font-normal leading-none mb-4 tracking-normal">
        <span class="text-primary">SUSTAINABLE DEVELOPMENT</span> 
        <span class="text-[#E64A19]">GOALS</span>
      </h2>
      <h3 class="font-mb101 font-black text-xl text-[#1A1A1A]">当社の取り組み</h3>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-5 gap-x-12 gap-y-16 lg:gap-x-16">
      {sdgsItems.map((item) => {
        return (
          <div class="flex flex-col items-center">
            <div class="w-full max-w-[170px] aspect-square shadow-sm overflow-hidden bg-white border border-gray-100 flex items-center justify-center p-4">
              <img 
                src={`/images/sdg-${item.id}.webp`} 
                alt={`SDG ${item.id}`} 
                class="w-full h-full object-contain"
                loading="lazy"
              />
            </div>
            <div class="mt-5 text-left w-full max-w-[170px] pl-[10px] md:pl-4">
              <p class="font-sans text-[11px] leading-relaxed font-medium text-gray-600 whitespace-pre-wrap" set:text={item.text} />
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
